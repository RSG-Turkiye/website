---
interface Member {
  name: string;
  role: string;
  image: string;
  institution: string;
  email?: string;
  socialMedia?: { platform: string; url: string }[];
  education?: { degree: string; field: string; institution: string; year: string }[];
}

const { name, description, members = [] } = Astro.props as { name: string; description: string; members: Member[] };

function initials(memberName: string) {
  const parts = memberName.trim().split(/\s+/);
  if (parts.length === 1) return parts[0][0].toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}
---
<div class="bg-white border border-border rounded-lg p-6">
  <h3 class="text-lg font-semibold text-navy text-center mb-1">{name}</h3>
  <p class="text-sm text-gray-500 text-center mb-6">{description}</p>

  <div class={`grid gap-4 justify-center ${members.length === 1 ? 'grid-cols-1 max-w-xs mx-auto' : members.length === 2 ? 'grid-cols-1 sm:grid-cols-2 max-w-sm sm:max-w-lg mx-auto' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'}`}>
    {members.map((member) => (
      <div class="text-center p-4 bg-navy-light border border-[#C4CEEA] rounded-lg hover:border-navy-mid transition-colors">
        <div class="w-24 h-24 rounded-full overflow-hidden mx-auto mb-3 border-2 border-navy-mid bg-navy flex items-center justify-center">
          {member.image
            ? <img src={member.image} alt={member.name} width="96" height="96" class="w-full h-full object-cover" />
            : <span class="text-white text-xl font-semibold">{initials(member.name)}</span>
          }
        </div>
        <h5 class="font-semibold text-navy text-sm mb-0.5">{member.name}</h5>
        <p class="text-xs text-navy-mid mb-1">{member.role}</p>

        {member.education && member.education.length > 0 && (
          <div class="mb-1">
            {member.education.map((edu) => (
              <p class="text-xs text-gray-400">
                {edu.degree} · {edu.field}
                {edu.institution && ` · ${edu.institution}`}
                {edu.year && ` (${edu.year})`}
              </p>
            ))}
          </div>
        )}

        <p class="text-xs text-gray-400 mb-2">{member.institution}</p>

        {member.socialMedia && member.socialMedia.length > 0 && (
          <div class="flex gap-2 justify-center flex-wrap">
            {member.socialMedia.map((social) => (
              <a href={social.url} target="_blank" rel="noopener noreferrer"
                class="text-navy-mid hover:text-navy transition-colors"
                title={social.platform}>
                {social.platform === 'linkedin' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {social.platform === 'twitter' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.741l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {social.platform === 'github' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                )}
                {social.platform === 'instagram' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                )}
                {social.platform === 'facebook' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</div>
