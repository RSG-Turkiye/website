---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "Webinars - RSG Turkey";

const allWebinars = await getCollection('webinars');
const enWebinars = allWebinars.filter(w => w.id.startsWith('en/'));
const sortedWebinars = enWebinars.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());


const speakerMap = new Map<string, { name: string; slug: string; photo: string }>();
enWebinars
  .filter(w => w.data.speaker)
  .forEach(w => {
    const key = w.data.speaker!.trim().toLowerCase();
    const existing = speakerMap.get(key);
    const photo = w.data.speakerPhoto || '';
    if (!existing || (!existing.photo && photo)) {
      speakerMap.set(key, { name: w.data.speaker!, slug: w.id.slice(3), photo });
    }
  });
const speakers = Array.from(speakerMap.values()).sort((a, b) => a.name.localeCompare(b.name));

function initials(name: string) {
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0][0].toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('webinars.title')}</h1>
      <p class="text-white/70 mt-2">{t('webinars.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">

        <!-- Posts -->
        <div>
          <div id="webinarList" class="flex flex-col">
            {sortedWebinars.map((webinar) => (
              <article
                class="webinar-item py-5 border-b border-border"
                data-title={webinar.data.title}
                data-speaker={webinar.data.speaker || ''}
                data-description={webinar.data.description || ''}
                data-year={String(webinar.data.year)}
              >
                <div class="flex items-center gap-3 text-xs text-gray-400 mb-2">
                  <time>{webinar.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  {webinar.data.speaker && <span>{webinar.data.speaker}</span>}
                </div>
                <h2 class="text-base font-semibold mb-1">
                  <a href={`/webinars/${webinar.id.slice(3)}`} class="text-navy hover:text-navy-mid transition-colors">
                    {webinar.data.title}
                  </a>
                </h2>
                {webinar.data.description && (
                  <p class="text-sm text-gray-500 leading-relaxed">{webinar.data.description}</p>
                )}
              </article>
            ))}
          </div>

          <!-- Pagination controls -->
          <div id="pagination" class="mt-8 flex items-center justify-between gap-2 flex-wrap"></div>
          <p id="noResults" class="hidden text-sm text-gray-500 py-4">No webinars match your search.</p>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-6">

          <!-- Search -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Search</p>
            <input
              type="text"
              id="searchWebinars"
              placeholder="Search webinars..."
              class="w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors"
            />
          </div>

          <!-- About the series -->
          <div class="rounded-lg border border-[#C4CEEA] bg-navy-light p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-navy-mid mb-2">About the Series</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              RSG Turkey hosts regular webinars featuring researchers in bioinformatics, structural biology, and computational biology — open to everyone.
            </p>
          </div>

          <!-- YouTube -->
          <div class="rounded-lg border border-border bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Watch on YouTube</p>
            <p class="text-sm text-gray-500 mb-3 leading-relaxed">All past webinar recordings are available on our YouTube channel.</p>
            <a href="https://www.youtube.com/@RSG-Turkiye" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded bg-red text-white text-sm font-medium hover:bg-red-hover transition-colors no-underline w-full justify-center">
              Subscribe
            </a>
          </div>

          <!-- Speakers -->
          {speakers.length > 0 && (
            <div class="rounded-lg border border-border bg-white p-5">
              <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
                Speakers <span class="text-gray-300 font-normal normal-case tracking-normal">({speakers.length})</span>
              </p>
              <div class="flex flex-wrap gap-2">
                {speakers.map((s) => (
                  <a
                    href={`/webinars/${s.slug}`}
                    class="speaker-avatar"
                    data-name={s.name}
                    aria-label={s.name}
                  >
                    <span class="avatar-inner">
                      {s.photo
                        ? <img src={s.photo} alt={s.name} class="w-full h-full object-cover" />
                        : initials(s.name)
                      }
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .speaker-avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    background-color: #1a2744;
    color: white;
    font-size: 10px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background-color 0.15s, transform 0.15s;
    cursor: pointer;
    overflow: visible;
  }
  .speaker-avatar .avatar-inner {
    width: 100%;
    height: 100%;
    border-radius: 7px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .speaker-avatar:hover {
    background-color: #2d4a8a;
    transform: scale(1.12);
    z-index: 10;
  }
  .speaker-avatar::after {
    content: attr(data-name);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a2744;
    color: white;
    padding: 4px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 20;
  }
  .speaker-avatar:hover::after {
    opacity: 1;
  }
</style>

<script>
  const PER_PAGE = 20;
  let currentPage = parseInt(new URLSearchParams(window.location.search).get('page') || '1') || 1;
  let filtered: HTMLElement[] = [];

  const allItems = () => Array.from(document.querySelectorAll<HTMLElement>('.webinar-item'));
  const searchInput = document.getElementById('searchWebinars') as HTMLInputElement;
  const paginationEl = document.getElementById('pagination')!;
  const noResults = document.getElementById('noResults')!;

  function setPageInUrl(page: number) {
    const url = new URL(window.location.href);
    page === 1 ? url.searchParams.delete('page') : url.searchParams.set('page', String(page));
    history.replaceState(null, '', url.toString());
  }

  function applyFilter(term: string) {
    filtered = allItems().filter(item => {
      const title = (item.dataset.title || '').toLowerCase();
      const speaker = (item.dataset.speaker || '').toLowerCase();
      const desc = (item.dataset.description || '').toLowerCase();
      return title.includes(term) || speaker.includes(term) || desc.includes(term);
    });
    currentPage = 1;
    render();
  }

  function render() {
    const items = allItems();
    items.forEach(item => item.style.display = 'none');

    const totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PER_PAGE;
    filtered.slice(start, start + PER_PAGE).forEach(item => item.style.display = '');

    noResults.classList.toggle('hidden', filtered.length > 0);
    setPageInUrl(currentPage);
    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    if (totalPages <= 1) { paginationEl.innerHTML = ''; return; }

    const btnClass = 'px-3 py-1.5 rounded border text-sm font-medium transition-colors';
    const activeClass = 'bg-navy text-white border-navy';
    const inactiveClass = 'border-border text-gray-600 hover:bg-navy-light hover:border-navy-mid';

    let html = `<button id="prevBtn" class="${btnClass} ${currentPage === 1 ? 'opacity-40 cursor-not-allowed border-border text-gray-400' : inactiveClass}"
      ${currentPage === 1 ? 'disabled' : ''}>← Prev</button>`;
    html += `<div class="flex items-center gap-1 flex-wrap">`;

    for (let p = 1; p <= totalPages; p++) {
      html += `<button class="page-btn ${btnClass} ${p === currentPage ? activeClass : inactiveClass}" data-page="${p}">${p}</button>`;
    }

    html += `</div>`;
    html += `<button id="nextBtn" class="${btnClass} ${currentPage === totalPages ? 'opacity-40 cursor-not-allowed border-border text-gray-400' : inactiveClass}"
      ${currentPage === totalPages ? 'disabled' : ''}>Next →</button>`;

    paginationEl.innerHTML = html;

    document.getElementById('prevBtn')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; render(); window.scrollTo(0, 0); } });
    document.getElementById('nextBtn')?.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; render(); window.scrollTo(0, 0); } });
    document.querySelectorAll('.page-btn').forEach(btn => {
      btn.addEventListener('click', () => { currentPage = parseInt((btn as HTMLElement).dataset.page!); render(); window.scrollTo(0, 0); });
    });
  }

  // Init — filter by year hash if present (e.g. #2025)
  const yearHash = window.location.hash.replace('#', '');
  if (yearHash && /^\d{4}$/.test(yearHash)) {
    filtered = allItems().filter(item => item.dataset.year === yearHash);
  } else {
    filtered = allItems();
  }
  render();

  searchInput?.addEventListener('input', function () {
    applyFilter(this.value.toLowerCase());
  });
</script>
