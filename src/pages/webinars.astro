---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "Webinars - RSG Turkey";

const allWebinars = await getCollection('webinars', ({ data }) => {
  return data.lang === 'en';
});

// Group webinars by year, sorted descending
const webinarsByYear = allWebinars.reduce((acc, w) => {
  const year = String(w.data.year);
  if (!acc[year]) acc[year] = [];
  acc[year].push(w);
  return acc;
}, {} as Record<string, typeof allWebinars>);

const sortedYears = Object.keys(webinarsByYear).sort((a, b) => Number(b) - Number(a));

const webinars = sortedYears.map((year) => ({
  year,
  title: `${year} Webinars`,
  webinars: webinarsByYear[year].map((w) => ({
    title: w.data.title,
    presenter: w.data.speaker,
    date: w.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' }),
    description: w.data.description,
    status: w.data.date > new Date() ? 'upcoming' : 'completed',
    youtubeUrl: w.data.youtubeUrl,
  })),
}));
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Hero Section -->
  <section class="hero text-center py-5">
    <div class="container">
      <div class="row align-items-center min-vh-50">
        <div class="col-lg-8 mx-auto">
          <h1 class="display-3 fw-bold mb-4">{t('webinars.title')}</h1>
          <p class="lead fs-4">
            {t('webinars.subtitle')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bioinfonet Project Section -->
  <section class="bioinfonet py-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <h2 class="display-5 fw-bold mb-4">{t('webinars.bioinfonet.title')}</h2>
          <p class="lead mb-4">
            {t('webinars.bioinfonet.description')}
          </p>
          <p class="fs-5 mb-4">
            {t('webinars.bioinfonet.detail')}
          </p>
          <div class="project-features">
            <div class="feature-item d-flex align-items-center mb-3">
              <i class="fas fa-globe fa-2x text-primary me-3"></i>
              <div>
                <h5 class="mb-1">{t('webinars.features.global.title')}</h5>
                <p class="text-muted mb-0">{t('webinars.features.global.description')}</p>
              </div>
            </div>
            <div class="feature-item d-flex align-items-center mb-3">
              <i class="fas fa-graduation-cap fa-2x text-primary me-3"></i>
              <div>
                <h5 class="mb-1">{t('webinars.features.expert.title')}</h5>
                <p class="text-muted mb-0">{t('webinars.features.expert.description')}</p>
              </div>
            </div>
            <div class="feature-item d-flex align-items-center">
              <i class="fas fa-users fa-2x text-primary me-3"></i>
              <div>
                <h5 class="mb-1">{t('webinars.features.interactive.title')}</h5>
                <p class="text-muted mb-0">{t('webinars.features.interactive.description')}</p>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-6 text-center">
          <div class="bioinfonet-logo p-4">
            <i class="fas fa-video fa-5x text-success mb-3"></i>
            <h4>Bioinfonet</h4>
            <p class="text-muted">ISCB Student Council Supported Project</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Webinar Years Section -->
  <section class="webinar-years py-5 bg-light">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center mb-5">
          <h2 class="display-5 fw-bold mb-4">{t('webinars.schedule.title')}</h2>
          <p class="lead">
            {t('webinars.schedule.subtitle')}
          </p>
        </div>
      </div>
      
      {webinars.map((yearGroup) => (
        <div class="webinar-year mb-5">
          <div class="row">
            <div class="col-12">
              <h3 class="h2 mb-4 text-center">{yearGroup.title}</h3>
              <div class="row g-4">
                {yearGroup.webinars.map((webinar) => (
                  <div class="col-lg-6 col-md-12">
                    <div class="webinar-card h-100">
                      <div class="card h-100">
                        <div class="card-body">
                          <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class={`badge ${webinar.status === 'upcoming' ? 'bg-accent' : 'bg-secondary'}`}>
                              {webinar.status === 'upcoming' ? t('webinars.status.upcoming') : t('webinars.status.completed')}
                            </span>
                            <small class="text-muted">{webinar.date}</small>
                          </div>
                          <h5 class="card-title mb-3">{webinar.title}</h5>
                          {webinar.presenter && (
                            <p class="text-primary fw-bold mb-2">
                              <i class="fas fa-user me-2"></i>{t('webinars.presenter')}: {webinar.presenter}
                            </p>
                          )}
                          <p class="card-text text-muted">{webinar.description}</p>
                          {webinar.status === 'upcoming' && (
                            <a href="/contact" class="btn btn-primary btn-sm">{t('webinars.register')}</a>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Open Student Webinars Section -->
  <section class="open-student-webinars py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <h2 class="display-5 fw-bold mb-4">Open Student Webinars</h2>
          <p class="lead mb-4">
            Our student-led webinar series featuring research presentations and discussions from the Turkish computational biology community.
          </p>
          <div class="row g-4 mt-4">
            <div class="col-md-6">
              <div class="student-webinar-card text-center p-4">
                <i class="fas fa-microscope fa-3x text-primary mb-3"></i>
                <h4>Research Presentations</h4>
                <p class="text-muted">
                  Students present their latest research findings and methodologies in computational biology.
                </p>
              </div>
            </div>
            <div class="col-md-6">
              <div class="student-webinar-card text-center p-4">
                <i class="fas fa-comments fa-3x text-primary mb-3"></i>
                <h4>Interactive Discussions</h4>
                <p class="text-muted">
                  Engage in discussions with peers and experts about current trends and challenges in the field.
                </p>
              </div>
            </div>
          </div>
          <div class="mt-4">
            <a href="/contact" class="btn btn-primary btn-lg px-4">Join Our Student Webinars</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="cta py-5 bg-primary">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <h2 class="display-5 fw-bold mb-4">Stay Connected</h2>
          <p class="lead mb-4">
            Don't miss out on our upcoming webinars and events. Join our community to receive notifications.
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
            <a href="/contact" class="btn btn-light btn-lg px-4">Contact Us</a>
            <a href="/join" class="btn btn-outline-light btn-lg px-4">Join Our Community</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #00539F 0%, #00d1b2 100%);
    min-height: 50vh;
    display: flex;
    align-items: center;
  }

  .min-vh-50 {
    min-height: 50vh;
  }

  .bioinfonet-logo {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border: 1px solid #dee2e6;
  }

  .webinar-card {
    transition: transform 0.3s ease;
  }

  .webinar-card:hover {
    transform: translateY(-5px);
  }

  .card {
    border: 1px solid #dee2e6;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .student-webinar-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border: 1px solid #dee2e6;
    transition: transform 0.3s ease;
  }

  .student-webinar-card:hover {
    transform: translateY(-5px);
  }

  .feature-item {
    font-size: 1.1rem;
  }
</style> 