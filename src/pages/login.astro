---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Sign In — RSG Turkey" description="Sign in to your RSG Turkey account.">
  <div class="min-h-screen bg-[#F7F7F6] flex items-center justify-center px-4">
    <div class="w-full max-w-md">

      <!-- Card -->
      <div class="bg-white rounded-2xl border border-border shadow-sm p-10 text-center">

        <!-- Logo -->
        <div class="flex justify-center mb-6">
          <img src="/logo/rsgturkey_logo.png" alt="RSG Turkey" width="56" height="56" class="rounded bg-navy p-1.5" />
        </div>

        <h1 class="text-2xl font-bold text-navy mb-2">Welcome to RSG Turkey</h1>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">
          Sign in to access your profile, track your learning progress, and connect with the bioinformatics community.
        </p>

        <!-- Google Sign In -->
        <a
          href="/auth/login"
          class="flex items-center justify-center gap-3 w-full px-6 py-3 rounded-xl border-2 border-border bg-white hover:border-navy-mid hover:shadow-sm transition-all no-underline text-navy font-semibold text-sm">
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </a>

        <p class="mt-6 text-xs text-gray-400 leading-relaxed">
          By signing in, your profile will be visible in the member directory.<br/>
          You can make it private anytime in your settings.
        </p>
      </div>

      <!-- Back link -->
      <div class="text-center mt-6">
        <a href="/" class="text-sm text-gray-400 hover:text-navy transition-colors no-underline">← Back to RSG Turkey</a>
      </div>

    </div>
  </div>
</BaseLayout>
