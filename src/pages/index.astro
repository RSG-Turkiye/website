---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "RSG Turkey - Computational Biology Community";

const latestPosts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout pageTitle={pageTitle}>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section
    class="py-24 text-center bg-navy bg-cover bg-center"
    style="background-image: linear-gradient(rgba(26,39,68,0.78), rgba(26,39,68,0.88)), url('https://res.cloudinary.com/dyuf14ra5/image/upload/f_auto,q_auto/404A1947_mzkouu');"
  >
    <div class="max-w-2xl mx-auto px-6">
      <img
        src="/logo/rsgturkey_logo.png"
        alt="RSG Turkey Logo"
        width="72" height="72"
        class="mx-auto mb-6 rounded-lg bg-white p-1"
      />
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight">
        {t('hero.title')}
      </h1>
      <p class="text-white/75 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
        {t('hero.description')}
      </p>
      <a
        href="/join"
        class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium text-base hover:bg-red-hover transition-colors no-underline"
      >
        {t('hero.joinCommunity')}
      </a>
    </div>
  </section>

  <!-- ── Mission + Stats ───────────────────────────────── -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 items-start">

        <!-- Mission text -->
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">{t('mission.title')}</h2>
          <p class="text-gray-600 leading-relaxed mb-3">{t('mission.description')}</p>
          <p class="text-gray-600 leading-relaxed">{t('mission.goal')}</p>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { n: '10+', label: t('stats.years') },
            { n: '50+', label: t('stats.members') },
            { n: '100+', label: t('stats.webinars') },
            { n: '15+', label: lang === 'tr' ? 'Sempozyum' : 'Symposiums' },
          ].map(({ n, label }) => (
            <div class="text-center p-5 rounded-lg bg-navy-light border border-[#C4CEEA]">
              <span class="block text-3xl font-bold text-navy">{n}</span>
              <span class="block text-sm text-gray-500 mt-1">{label}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ── Content Cards ─────────────────────────────────── -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border border-b">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('contentCards.title')}</h2>
      <p class="text-gray-500 text-center max-w-lg mx-auto mb-10">{t('contentCards.subtitle')}</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Webinar card -->
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-[#FDEAEA] text-red mb-4">
            Webinar
          </span>
          <h3 class="text-base font-semibold text-navy mb-2">{t('contentCards.webinar.title')}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-4">{t('contentCards.webinar.description')}</p>
          <a href="/webinars" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors">
            {t('contentCards.webinar.button')} →
          </a>
        </div>

        <!-- Events card -->
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-[#FDEAEA] text-red mb-4">
            {lang === 'tr' ? 'Etkinlik' : 'Event'}
          </span>
          <h3 class="text-base font-semibold text-navy mb-2">{t('contentCards.events.title')}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-4">{t('contentCards.events.description')}</p>
          <a href="/events" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors">
            {t('contentCards.events.button')} →
          </a>
        </div>

        <!-- Blog card -->
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-[#FDEAEA] text-red mb-4">
            Blog
          </span>
          <h3 class="text-base font-semibold text-navy mb-2">{t('contentCards.blog.title')}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-4">{t('contentCards.blog.description')}</p>
          <a href="/blog" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors">
            {t('contentCards.blog.button')} →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Join CTA ──────────────────────────────────────── -->
  <section class="bg-white py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy mb-3">{t('cta.title')}</h2>
      <p class="text-gray-500 mb-6">{t('cta.description')}</p>
      <a
        href="/join"
        class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium hover:bg-red-hover transition-colors no-underline"
      >
        {t('cta.joinToday')}
      </a>
    </div>
  </section>

</BaseLayout>
