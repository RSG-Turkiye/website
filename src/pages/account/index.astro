---
import BaseLayout from '../../layouts/BaseLayout.astro';

const BADGE_LABELS: Record<string, string> = {
  open_to_work:        'Looking for a job / internship',
  open_to_collaborate: 'Open to collaborate on a project',
  open_to_mentor:      'Open to mentoring',
  seeking_mentor:      'Looking for a mentor',
  open_to_review:      'Open to reviewing papers / code',
};
---

<BaseLayout pageTitle="My Profile — RSG Turkey" description="Your RSG Turkey member profile.">
  <div class="min-h-screen bg-[#F7F7F6] py-12 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Loading state -->
      <div id="loadingState" class="flex items-center justify-center py-24">
        <div class="w-8 h-8 border-2 border-navy border-t-transparent rounded-full animate-spin"></div>
      </div>

      <!-- Not logged in -->
      <div id="notLoggedIn" class="hidden text-center py-24">
        <p class="text-gray-500 mb-4">You need to sign in to view your profile.</p>
        <a href="/login" class="inline-flex px-6 py-2.5 rounded-xl bg-navy text-white text-sm font-semibold no-underline hover:bg-navy-mid transition-colors">Sign In</a>
      </div>

      <!-- No profile yet -->
      <div id="noProfile" class="hidden text-center py-24">
        <p class="text-gray-500 mb-4">You haven't set up your profile yet.</p>
        <a href="/account/setup" class="inline-flex px-6 py-2.5 rounded-xl bg-navy text-white text-sm font-semibold no-underline hover:bg-navy-mid transition-colors">Set Up Profile</a>
      </div>

      <!-- Profile content -->
      <div id="profileContent" class="hidden flex flex-col gap-6">

        <!-- Profile card -->
        <div class="bg-white rounded-2xl border border-border shadow-sm p-8">
          <div class="flex items-start gap-6">
            <!-- Avatar -->
            <div id="avatarWrap" class="shrink-0">
              <div class="w-20 h-20 rounded-full bg-navy-light flex items-center justify-center text-2xl text-navy font-bold" id="avatarFallback"></div>
            </div>
            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h1 id="displayName" class="text-xl font-bold text-navy"></h1>
                  <p id="usernameEl" class="text-sm text-gray-400"></p>
                </div>
                <a href="/account/setup" class="shrink-0 text-xs px-3 py-1.5 rounded-lg border border-border text-gray-500 hover:border-navy-mid hover:text-navy transition-colors no-underline">Edit profile</a>
              </div>
              <p id="institutionEl" class="text-sm text-gray-500 mt-1 hidden"></p>
              <p id="bioEl" class="text-sm text-gray-600 mt-3 leading-relaxed hidden"></p>
            </div>
          </div>

          <!-- Member badge -->
          <div id="memberBadge" class="hidden mt-5 pt-5 border-t border-border">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1 rounded-full bg-green-50 text-green-700 border border-green-200">
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Verified RSG Turkey Member
            </span>
          </div>
        </div>

        <!-- Status badges -->
        <div id="badgesCard" class="hidden bg-white rounded-2xl border border-border shadow-sm p-6">
          <h2 class="text-sm font-semibold text-navy mb-3">Status</h2>
          <div id="badgesList" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Interests -->
        <div id="interestsCard" class="hidden bg-white rounded-2xl border border-border shadow-sm p-6">
          <h2 class="text-sm font-semibold text-navy mb-3">Research interests</h2>
          <div id="interestsList" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Membership CTA -->
        <div id="membershipCta" class="hidden bg-white rounded-2xl border border-border shadow-sm p-6 flex items-start gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-navy-light flex items-center justify-center text-navy">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <h2 class="text-sm font-semibold text-navy mb-1">Become an RSG Turkey member</h2>
            <p class="text-sm text-gray-500 mb-3">Fill out our membership form to get verified and unlock your member badge.</p>
            <a href="/join" class="inline-flex px-4 py-2 rounded-lg bg-navy text-white text-sm font-medium no-underline hover:bg-navy-mid transition-colors">Apply for membership →</a>
          </div>
        </div>

        <!-- Sign out -->
        <div class="flex justify-end">
          <form action="/auth/logout" method="POST">
            <button type="submit" class="text-sm text-gray-400 hover:text-red transition-colors">Sign out</button>
          </form>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ BADGE_LABELS }}>
  (async () => {
    const loading = document.getElementById('loadingState');
    const notLoggedIn = document.getElementById('notLoggedIn');
    const noProfile = document.getElementById('noProfile');
    const profileContent = document.getElementById('profileContent');

    try {
      const res = await fetch('/api/me');
      const data = await res.json();

      loading.classList.add('hidden');

      if (!data.user) {
        notLoggedIn.classList.remove('hidden');
        return;
      }

      if (!data.profile) {
        noProfile.classList.remove('hidden');
        return;
      }

      profileContent.classList.remove('hidden');

      const p = data.profile;

      // Avatar
      const avatarWrap = document.getElementById('avatarWrap');
      const avatarFallback = document.getElementById('avatarFallback');
      if (p.avatar_url) {
        avatarWrap.innerHTML = `<img src="${p.avatar_url}" class="w-20 h-20 rounded-full object-cover" />`;
      } else {
        avatarFallback.textContent = p.display_name.charAt(0).toUpperCase();
      }

      // Basic info
      document.getElementById('displayName').textContent = p.display_name;
      document.getElementById('usernameEl').textContent = '@' + p.username;

      if (p.institution) {
        const el = document.getElementById('institutionEl');
        el.textContent = p.institution;
        el.classList.remove('hidden');
      }

      if (p.bio) {
        const el = document.getElementById('bioEl');
        el.textContent = p.bio;
        el.classList.remove('hidden');
      }

      // Member badge
      if (data.user.is_member) {
        document.getElementById('memberBadge').classList.remove('hidden');
      } else {
        document.getElementById('membershipCta').classList.remove('hidden');
      }

      // Status badges
      if (data.badges && data.badges.length > 0) {
        const card = document.getElementById('badgesCard');
        const list = document.getElementById('badgesList');
        card.classList.remove('hidden');
        data.badges.forEach(badge => {
          const span = document.createElement('span');
          span.className = 'text-xs px-3 py-1.5 rounded-full bg-navy-light text-navy border border-navy/20 font-medium';
          span.textContent = BADGE_LABELS[badge] || badge;
          list.appendChild(span);
        });
      }

      // Interests
      if (data.interests && data.interests.length > 0) {
        const card = document.getElementById('interestsCard');
        const list = document.getElementById('interestsList');
        card.classList.remove('hidden');
        data.interests.forEach(interest => {
          const span = document.createElement('span');
          span.className = 'text-xs px-3 py-1.5 rounded-full bg-[#F7F7F6] text-gray-600 border border-border';
          span.textContent = interest;
          list.appendChild(span);
        });
      }

    } catch (e) {
      loading.classList.add('hidden');
      notLoggedIn.classList.remove('hidden');
    }
  })();
</script>
