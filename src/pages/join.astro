---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Join Us - RSG Turkiye";

const faqs = [
  {
    q: "How can I join RSG Turkiye?",
    a: "Anyone interested in computational biology and bioinformatics is welcome to join. Fill out the membership form above or reach out to us at turkey.rsg@gmail.com.",
  },
  {
    q: "Are your events open to international participants?",
    a: "Yes! Many of our events, especially webinars, are open to international participants. We welcome collaboration and participation from researchers worldwide.",
  },
  {
    q: "How can I stay updated about upcoming events?",
    a: "Follow us on Twitter, LinkedIn, or YouTube, or check this website regularly for event announcements.",
  },
  {
    q: "Can I propose a webinar or workshop topic?",
    a: "Absolutely! We welcome suggestions for webinar topics and workshop themes. Contact us at turkey.rsg@gmail.com with your proposal.",
  },
];

const benefits = [
  { title: 'International Network', desc: 'Connect with researchers worldwide through ISCB Student Council affiliation' },
  { title: 'Learning Opportunities', desc: 'Access to webinars, workshops, and educational resources' },
  { title: 'Community Support', desc: 'Join a supportive community of computational biology enthusiasts' },
  { title: 'Career Development', desc: 'Career fairs, networking events, and professional development opportunities' },
  { title: 'Collaboration', desc: 'Opportunities to collaborate on research projects and events' },
  { title: 'Event Access', desc: 'Priority access to symposiums, workshops, and special events' },
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">Join RSG Turkiye</h1>
      <p class="text-white/70 mt-2">Become part of Turkey's bioinformatics student community</p>
    </div>
  </div>

  <section class="bg-white py-14">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Benefits -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">Why join?</h2>
          <ul class="flex flex-col">
            {benefits.map((b) => (
              <li class="py-3 border-b border-border flex flex-col gap-0.5">
                <strong class="text-navy text-sm">{b.title}</strong>
                <span class="text-sm text-gray-500">{b.desc}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Form embed -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">Membership Application</h2>
          <iframe
            src="https://docs.google.com/forms/d/e/1FAIpQLSeo8lI8mijdndi2Z0hURHUbn2mvJPkbW9OrsgQ2bH9iGfyS_g/viewform?embedded=true"
            width="100%"
            height="900"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            class="rounded-lg border border-border"
            title="RSG Turkiye Membership Application Form"
          >
            Loading form…
          </iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#F7F7F6] py-14 border-t border-border">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-xl font-semibold text-navy text-center mb-8">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-2">
        {faqs.map((faq) => (
          <div class="bg-white border border-border rounded-lg overflow-hidden">
            <button
              class="w-full flex justify-between items-center px-5 py-4 text-left text-sm font-medium text-navy hover:bg-navy-light transition-colors"
              aria-expanded="false"
              onclick="const b=this.nextElementSibling;const open=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!open));b.style.display=open?'none':'block'"
            >
              {faq.q}
              <span class="text-xl font-light text-gray-400 ml-4 shrink-0">+</span>
            </button>
            <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed" style="display:none;">
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
