---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "Join Us - RSG Turkey";

const benefits = [
  { title: lang === 'tr' ? 'Uluslararası Ağ' : 'International Network', desc: lang === 'tr' ? 'ISCB Öğrenci Konseyi bağlantısı ile dünya çapında araştırmacılarla bağlantı kurun' : 'Connect with researchers worldwide through ISCB Student Council affiliation' },
  { title: lang === 'tr' ? 'Öğrenme Fırsatları' : 'Learning Opportunities', desc: lang === 'tr' ? 'Webinarlara, atölyelere ve eğitim kaynaklarına erişim' : 'Access to webinars, workshops, and educational resources' },
  { title: lang === 'tr' ? 'Topluluk Desteği' : 'Community Support', desc: lang === 'tr' ? 'Hesaplamalı biyoloji meraklılarından oluşan destekleyici bir topluluğa katılın' : 'Join a supportive community of computational biology enthusiasts' },
  { title: lang === 'tr' ? 'Kariyer Gelişimi' : 'Career Development', desc: lang === 'tr' ? 'Kariyer fuarları, ağ oluşturma etkinlikleri ve profesyonel gelişim fırsatları' : 'Career fairs, networking events, and professional development opportunities' },
  { title: lang === 'tr' ? 'İşbirliği' : 'Collaboration', desc: lang === 'tr' ? 'Araştırma projelerinde ve etkinliklerde işbirliği fırsatları' : 'Opportunities to collaborate on research projects and events' },
  { title: lang === 'tr' ? 'Etkinlik Erişimi' : 'Event Access', desc: lang === 'tr' ? 'Sempozyumlara, atölyelere ve özel etkinliklere öncelikli erişim' : 'Priority access to symposiums, workshops, and special events' },
];

const membershipTypes = [
  {
    type: lang === 'tr' ? 'Öğrenci Üye' : 'Student Member',
    description: lang === 'tr' ? 'Lisans ve lisansüstü öğrenciler için' : 'For undergraduate and graduate students',
    features: lang === 'tr'
      ? ['Tüm webinar ve etkinliklere erişim', 'Öğrenci sunum fırsatları', 'Mentorluk programları', 'Kaynak kütüphanesine erişim']
      : ['Access to all webinars and events', 'Student presentation opportunities', 'Mentorship programs', 'Resource library access'],
  },
  {
    type: lang === 'tr' ? 'Erken Kariyer Araştırmacı' : 'Early Career Researcher',
    description: lang === 'tr' ? 'Doktora sonrası ve erken kariyer araştırmacıları için' : 'For postdocs and early career researchers',
    features: lang === 'tr'
      ? ['Tüm öğrenci üye avantajları', 'Liderlik fırsatları', 'Komite katılımı', 'Uluslararası konferans desteği']
      : ['All student member benefits', 'Leadership opportunities', 'Committee participation', 'International conference support'],
  },
  {
    type: lang === 'tr' ? 'Profesyonel Üye' : 'Professional Member',
    description: lang === 'tr' ? 'Yerleşik profesyoneller ve akademisyenler için' : 'For established professionals and faculty',
    features: lang === 'tr'
      ? ['Tüm üye avantajları', 'Mentorluk fırsatları', 'Etkinlik organizasyon rolleri', 'Uluslararası işbirliği kolaylaştırma']
      : ['All member benefits', 'Mentoring opportunities', 'Event organization roles', 'International collaboration facilitation'],
  },
];
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Page Header -->
  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('join.title')}</h1>
      <p class="text-white/70 mt-2">{t('join.subtitle')}</p>
    </div>
  </div>

  <!-- Benefits + Membership Types -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Benefits -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">{t('join.benefits.title')}</h2>
          <ul class="flex flex-col">
            {benefits.map((b) => (
              <li class="py-3 border-b border-border flex flex-col gap-0.5">
                <strong class="text-navy text-sm">{b.title}</strong>
                <span class="text-sm text-gray-500">{b.desc}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Membership Types -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">{lang === 'tr' ? 'Üyelik Türleri' : 'Membership Types'}</h2>
          <div class="flex flex-col gap-3">
            {membershipTypes.map((m) => (
              <div class="p-4 bg-navy-light border border-[#C4CEEA] rounded-lg hover:border-navy-mid transition-colors">
                <h3 class="font-semibold text-navy text-sm mb-0.5">{m.type}</h3>
                <p class="text-xs text-gray-500 mb-2">{m.description}</p>
                <ul class="list-disc list-inside text-xs text-gray-600 space-y-0.5">
                  {m.features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Membership Form -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-8">
        {lang === 'tr' ? 'Üyelik Başvurusu' : 'Membership Application'}
      </h2>
      <form id="membershipForm" class="flex flex-col gap-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="firstName" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Ad' : 'First Name'} *</label>
            <input type="text" id="firstName" name="firstName" required class="input-field" />
          </div>
          <div>
            <label for="lastName" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Soyad' : 'Last Name'} *</label>
            <input type="text" id="lastName" name="lastName" required class="input-field" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="email" class="block text-sm font-medium text-navy mb-1">{t('join.form.email')} *</label>
            <input type="email" id="email" name="email" required class="input-field" />
          </div>
          <div>
            <label for="institution" class="block text-sm font-medium text-navy mb-1">{t('join.form.institution')} *</label>
            <input type="text" id="institution" name="institution" required class="input-field" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="position" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Pozisyon/Ünvan' : 'Position/Title'} *</label>
            <input type="text" id="position" name="position" required class="input-field" />
          </div>
          <div>
            <label for="membershipType" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Üyelik Türü' : 'Membership Type'} *</label>
            <select id="membershipType" name="membershipType" required class="input-field">
              <option value="">{lang === 'tr' ? 'Seçin...' : 'Choose...'}</option>
              <option value="student">{lang === 'tr' ? 'Öğrenci Üye' : 'Student Member'}</option>
              <option value="early-career">{lang === 'tr' ? 'Erken Kariyer Araştırmacı' : 'Early Career Researcher'}</option>
              <option value="professional">{lang === 'tr' ? 'Profesyonel Üye' : 'Professional Member'}</option>
            </select>
          </div>
        </div>
        <div>
          <label for="researchInterests" class="block text-sm font-medium text-navy mb-1">{t('join.form.research')}</label>
          <textarea id="researchInterests" name="researchInterests" rows="3" class="input-field resize-y"></textarea>
        </div>
        <div>
          <label for="motivation" class="block text-sm font-medium text-navy mb-1">{t('join.form.motivation')} *</label>
          <textarea id="motivation" name="motivation" rows="4" required class="input-field resize-y"></textarea>
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" id="newsletter" name="newsletter" checked class="mt-0.5 accent-navy" />
          <label for="newsletter" class="text-sm text-gray-600">
            {lang === 'tr' ? 'Etkinlik ve webinarlar hakkında güncellemeler almak için bültenimize abone olun' : 'Subscribe to our newsletter for updates about events and webinars'}
          </label>
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" id="agree" name="agree" required class="mt-0.5 accent-navy" />
          <label for="agree" class="text-sm text-gray-600">
            {lang === 'tr' ? 'Şartları ve koşulları kabul ediyorum' : 'I agree to the terms and conditions'} *
          </label>
        </div>
        <div class="text-center pt-2">
          <button type="submit"
            class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium hover:bg-red-hover transition-colors">
            {t('join.form.submit')}
          </button>
        </div>
        <div id="membershipFormMessage"></div>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors bg-white;
  }
</style>

<script>
  const membershipForm = document.getElementById('membershipForm') as HTMLFormElement;
  const msgDiv = document.getElementById('membershipFormMessage');
  if (membershipForm && msgDiv) {
    membershipForm.addEventListener('submit', function(e) {
      e.preventDefault();
      msgDiv.className = 'mt-2 p-3 rounded bg-green-50 text-green-800 border border-green-200 text-sm';
      msgDiv.textContent = 'Thank you for your application! We will review it and get back to you soon.';
      this.reset();
    });
  }
</script>
