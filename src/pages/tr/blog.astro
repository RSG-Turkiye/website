---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';
import { getCollection } from 'astro:content';

const lang = 'tr';
const t = useTranslations(lang);

const allBlogPosts = await getCollection('blog', ({ data }) => data.lang === 'tr' && !data.draft && data.type !== 'webinar');
const sortedPosts = allBlogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const pageTitle = "Blog - RSG Türkiye";

const facts = [
  "RSG Türkiye, hakemli bir dergide yayımlanmış akademik makalesi olan bir topluluktur.",
  "RSG Türkiye, 2012 yılında günümüzdeki danışmanımız Prof. Nurcan Tunçbağ ile birlikte kuruldu.",
  "Her yıl amiral gemisi etkinliğimiz olan sempozyumumuzu düzenliyoruz.",
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('blog.title')}</h1>
      <p class="text-white/70 mt-2">{t('blog.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">

        <!-- Posts -->
        <div>
          {sortedPosts.slice(0, 2).map((post: any) => (
            <article class="post-item py-5 border-b border-border"
              data-title={post.data.title}
              data-description={post.data.description || ''}>
              <div class="flex items-center gap-3 text-xs text-gray-400 mb-2">
                <time>{new Date(post.data.pubDate).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                {post.data.author && <span>{post.data.author}</span>}
              </div>
              <h2 class="text-lg font-semibold mb-1">
                <a href={`/tr/blog/${post.id}`} class="text-navy hover:text-navy-mid transition-colors">{post.data.title}</a>
              </h2>
              {post.data.description && <p class="text-sm text-gray-500 leading-relaxed mb-2">{post.data.description}</p>}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}

          <div id="postsGrid">
            {sortedPosts.slice(2).map((post: any) => (
              <article class="post-item py-4 border-b border-border"
                data-title={post.data.title}
                data-description={post.data.description || ''}>
                <div class="flex items-center gap-3 text-xs text-gray-400 mb-1">
                  <time>{new Date(post.data.pubDate).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  {post.data.author && <span>{post.data.author}</span>}
                </div>
                <h3 class="text-base font-semibold mb-1">
                  <a href={`/tr/blog/${post.id}`} class="text-navy hover:text-navy-mid transition-colors">{post.data.title}</a>
                </h3>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag: string) => (
                      <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{tag}</span>
                    ))}
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-6">

          <!-- Search -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Arama</p>
            <input type="text" id="searchPosts" placeholder={t('blog.search')}
              class="w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors" />
          </div>

          <!-- About RSG Turkey -->
          <div class="rounded-lg border border-[#C4CEEA] bg-navy-light p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-navy-mid mb-2">RSG Türkiye Hakkında</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              RSG Türkiye, Türkiye'deki ISCB Bölgesel Öğrenci Grubu'dur. Biyoinformatik ve hesaplamalı biyoloji alanındaki öğrencileri ve genç araştırmacıları bir araya getirir.
            </p>
            <a href="/tr/about" class="inline-block mt-3 text-xs font-medium text-navy-mid hover:text-navy transition-colors no-underline">
              Daha fazla →
            </a>
          </div>

          <!-- Did you know? -->
          <div class="rounded-lg border border-border bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Biliyor muydunuz?</p>
            <ul class="flex flex-col gap-3">
              {facts.map((fact) => (
                <li class="flex items-start gap-2 text-sm text-gray-600 leading-snug">
                  <span class="shrink-0 mt-0.5 text-red font-bold">✦</span>
                  {fact}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchPosts') as HTMLInputElement;
    if (!searchInput) return;
    searchInput.addEventListener('input', function() {
      const term = this.value.toLowerCase();
      document.querySelectorAll<HTMLElement>('.post-item').forEach(item => {
        const title = (item.dataset.title || '').toLowerCase();
        const desc = (item.dataset.description || '').toLowerCase();
        item.style.display = (title.includes(term) || desc.includes(term)) ? '' : 'none';
      });
    });
  });
</script>
