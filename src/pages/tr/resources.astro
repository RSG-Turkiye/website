---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'tr';
const t = useTranslations(lang);
const pageTitle = "Kaynaklar - RSG Türkiye";

const resources = [
  {
    category: t('resources.educational.title'),
    items: [
      { title: "Biyoinformatik: Nereden Başlamalı?", description: "Biyoinformatik konusunda nereden/nasıl başlanacağı sorusuna çözüm sunmak için basitleştirilmiş bir kaynak listesi.", type: "rehber", link: "#", tags: ["başlangıç", "öğrenme-yolu"] },
      { title: "Hesaplamalı Biyoloji Temelleri", description: "Hesaplamalı biyoloji ve biyoinformatikte temel kavramlar ve metodolojiler.", type: "kurs", link: "#", tags: ["temel", "kurs"] },
      { title: "Biyoinformatikte İstatistiksel Analiz", description: "Biyoinformatik araştırma ve veri analizinde yaygın kullanılan istatistiksel yöntemler.", type: "eğitim", link: "#", tags: ["istatistik", "analiz"] },
    ]
  },
  {
    category: t('resources.tools.title'),
    items: [
      { title: "Dizi Analiz Araçları", description: "DNA/RNA dizi analizi, hizalama ve açıklama için araç koleksiyonu.", type: "araçlar", link: "#", tags: ["dizi-analizi", "hizalama"] },
      { title: "Protein Yapısı Analizi", description: "Protein yapısı tahmin, analiz ve görselleştirme araçları.", type: "araçlar", link: "#", tags: ["protein-yapısı", "tahmin"] },
      { title: "Tek Hücreli Analiz Pipeline'ı", description: "Tek hücreli RNA dizileme verisi analizi için kapsamlı pipeline.", type: "pipeline", link: "#", tags: ["tek-hücreli", "rna-seq"] },
    ]
  },
  {
    category: t('resources.databases.title'),
    items: [
      { title: "Genomik Veritabanları", description: "Araştırma verileri için büyük genomik veritabanları ve depolarına erişim.", type: "veritabanı", link: "#", tags: ["genomik", "veri"] },
      { title: "Protein Veritabanları", description: "Araştırma ve analiz için protein dizisi ve yapı veritabanları.", type: "veritabanı", link: "#", tags: ["proteinler", "yapılar"] },
      { title: "Ekspresyon Veri Depoları", description: "Gen ekspresyon veri depoları ve analiz platformları.", type: "veritabanı", link: "#", tags: ["ekspresyon", "transkriptomik"] },
    ]
  },
  {
    category: t('resources.career.title'),
    items: [
      { title: "Kariyer Gelişimi Rehberi", description: "Hesaplamalı biyoloji ve biyoinformatikte kariyer gelişimi için rehberlik.", type: "rehber", link: "#", tags: ["kariyer", "gelişim"] },
      { title: "İş Fırsatları", description: "Hesaplamalı biyoloji alanındaki güncel iş ilanları ve fırsatlar.", type: "iş", link: "#", tags: ["iş", "fırsatlar"] },
    ]
  }
];

const externalLinks = [
  { title: "ISCB Öğrenci Konseyi", description: "Uluslararası Hesaplamalı Biyoloji Derneği Öğrenci Konseyi", url: "https://www.iscb.org/iscb-student-council" },
  { title: "Bioinformatics.org", description: "Dünya hesaplamalı biyoloji topluluğuna açık erişim", url: "https://www.bioinformatics.org" },
  { title: "NCBI Kaynakları", description: "Ulusal Biyoteknoloji Bilgi Merkezi kaynakları ve araçları", url: "https://www.ncbi.nlm.nih.gov" },
  { title: "EMBL-EBI", description: "Avrupa Biyoinformatik Enstitüsü kaynakları ve hizmetleri", url: "https://www.ebi.ac.uk" },
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('resources.title')}</h1>
      <p class="text-white/70 mt-2">{t('resources.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      {resources.map((category) => (
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">{category.category}</h2>
          <div class="flex flex-col">
            {category.items.map((item) => (
              <div class="py-4 border-b border-border">
                <div class="flex items-center gap-2 mb-1">
                  <a href={item.link} class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title}</a>
                  <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{item.type}</span>
                </div>
                <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <span class="inline-block text-xs px-2 py-0.5 rounded bg-[#F7F7F6] text-gray-400 border border-border">{tag}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-xl font-semibold text-navy mb-6">Harici Kaynaklar</h2>
      <ul class="flex flex-col">
        {externalLinks.map((link) => (
          <li class="py-4 border-b border-border">
            <a href={link.url} target="_blank" rel="noopener noreferrer"
              class="font-medium text-navy-mid hover:text-navy transition-colors">{link.title}</a>
            <span class="text-sm text-gray-500"> — {link.description}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>
