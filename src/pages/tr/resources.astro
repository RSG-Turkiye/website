---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Kaynaklar - RSG Türkiye";

const learningResources = [
  {
    title: "Rosalind",
    description: "Problem çözerek biyoinformatik öğrenin. Python, algoritmalar ve klasik biyoinformatik problemlerini interaktif olarak kapsar.",
    url: "https://rosalind.info",
    tags: ["başlangıç", "algoritmalar", "python"],
  },
  {
    title: "OSSU Bioinformatics",
    description: "Kapsamlı bir biyoinformatik eğitimi için ücretsiz, açık kaynaklı ve kendi hızınızda ilerleyebileceğiniz müfredat.",
    url: "https://github.com/ossu/bioinformatics",
    tags: ["müfredat", "kendi-hızında", "ücretsiz"],
  },
  {
    title: "EMBL-EBI Eğitim",
    description: "Avrupa Biyoinformatik Enstitüsü'nden biyoinformatik, genomik, proteomik ve veri analizi alanlarında ücretsiz çevrimiçi kurslar.",
    url: "https://www.ebi.ac.uk/training",
    tags: ["kurslar", "genomik", "proteomik"],
  },
  {
    title: "Harvard HBC Eğitim Materyalleri",
    description: "Harvard Chan Biyoinformatik Çekirdeği'nin RNA-seq, ChIP-seq, tek hücreli RNA-seq ve daha fazlasını kapsayan atölye materyalleri.",
    url: "https://hbctraining.github.io/main",
    tags: ["atölyeler", "rna-seq", "tek-hücreli"],
  },
  {
    title: "StatQuest — Josh Starmer",
    description: "Biyoloji ve biyoinformatiğe odaklanan, açık anlatımıyla istatistik ve makine öğrenimi kavramlarını ele alan YouTube kanalı.",
    url: "https://www.youtube.com/@statquest",
    tags: ["istatistik", "makine-öğrenimi", "youtube"],
  },
  {
    title: "The Carpentries",
    description: "Araştırmacılar için tasarlanmış Shell, Git, Python ve R derslerini içeren uygulamalı veri ve hesaplama becerileri materyalleri.",
    url: "https://carpentries.org",
    tags: ["programlama", "veri-becerileri", "atölyeler"],
  },
  {
    title: "Bioinformatics Specialization (Coursera)",
    description: "Pavel Pevzner ve Phillip Compeau'nun (UC San Diego) hazırladığı, algoritmaları ve dizi analizini kapsayan yedi derslik uzmanlaşma programı.",
    url: "https://www.coursera.org/specializations/bioinformatics",
    tags: ["algoritmalar", "coursera", "dizi-analizi"],
  },
];

const databases = [
  {
    title: "NCBI",
    description: "Ulusal Biyoteknoloji Bilgi Merkezi — GenBank, PubMed, BLAST, RefSeq ve daha pek çok temel veritabanının evi.",
    url: "https://www.ncbi.nlm.nih.gov",
    tags: ["genomik", "literatür", "diziler"],
  },
  {
    title: "UniProt",
    description: "Swiss-Prot (küratörlü) ve TrEMBL (otomatik) bölümlerini kapsayan kapsamlı protein dizisi ve fonksiyonel açıklama veritabanı.",
    url: "https://www.uniprot.org",
    tags: ["proteinler", "açıklama"],
  },
  {
    title: "RCSB Protein Veri Bankası (PDB)",
    description: "X-ışını, NMR ve kryo-EM ile belirlenen proteinlerin, nükleik asitlerin ve kompleks yapıların 3B yapısal verilerinin arşivi.",
    url: "https://www.rcsb.org",
    tags: ["protein-yapısı", "3b"],
  },
  {
    title: "AlphaFold Protein Yapısı Veritabanı",
    description: "DeepMind ve EMBL-EBI tarafından üretilen, neredeyse tüm bilinen proteinler için yapay zeka tarafından tahmin edilmiş protein yapıları.",
    url: "https://alphafold.ebi.ac.uk",
    tags: ["protein-yapısı", "YZ", "tahmin"],
  },
  {
    title: "Ensembl",
    description: "EMBL-EBI tarafından yönetilen, omurgalı ve model organizma genomları için genom tarayıcısı ve açıklama veritabanı.",
    url: "https://www.ensembl.org",
    tags: ["genom", "açıklama", "tarayıcı"],
  },
  {
    title: "GEO — Gen Ekspresyonu Omnibus",
    description: "Yüksek işlem hacimli gen ekspresyonu ve fonksiyonel genomik verileri (mikrodizi, RNA-seq vb.) için herkese açık depo.",
    url: "https://www.ncbi.nlm.nih.gov/geo",
    tags: ["gen-ekspresyonu", "transkriptomik"],
  },
  {
    title: "STRING",
    description: "Deney, metin madenciliği ve genomikten elde edilen verileri entegre eden bilinen ve tahmin edilen protein-protein etkileşim veritabanı.",
    url: "https://string-db.org",
    tags: ["protein-etkileşimleri", "ağlar"],
  },
  {
    title: "KEGG",
    description: "Kyoto Genlerin ve Genomiğin Ansiklopedisi — biyolojik yollar, hastalıklar, ilaçlar ve genomlar için referans veritabanı.",
    url: "https://www.kegg.jp",
    tags: ["yollar", "metabolizma"],
  },
  {
    title: "Human Cell Atlas",
    description: "Tek hücreli genomik ve uzamsal transkriptomik kullanarak insan vücudundaki her hücre tipini haritalamaya yönelik uluslararası girişim.",
    url: "https://www.humancellatlas.org",
    tags: ["tek-hücreli", "atlas", "transkriptomik"],
  },
  {
    title: "GTEx Portalı",
    description: "İnsan dokularındaki gen ekspresyonu verileri ve bunları düzenleyen genetik varyantlar (eQTL'ler).",
    url: "https://gtexportal.org",
    tags: ["gen-ekspresyonu", "eQTL", "dokular"],
  },
];

const tools = [
  {
    title: "Galaxy Project",
    description: "Komut satırı gerektirmeyen, erişilebilir ve tekrarlanabilir biyoinformatik analiz için web tabanlı platform.",
    url: "https://usegalaxy.org",
    tags: ["web-platformu", "tekrarlanabilir", "başlangıç"],
  },
  {
    title: "Bioconductor",
    description: "Diferansiyel ekspresyon, ChIP-seq, tek hücreli analiz ve daha fazlası için açık kaynaklı R paketleri.",
    url: "https://www.bioconductor.org",
    tags: ["R", "paketler", "genomik"],
  },
  {
    title: "GATK",
    description: "Broad Enstitüsü'nün Genom Analiz Araç Seti — yüksek işlem hacimli dizileme verilerinde varyant keşfi için endüstri standardı araçlar.",
    url: "https://gatk.broadinstitute.org",
    tags: ["varyant-çağırma", "WGS", "WES"],
  },
  {
    title: "Nextflow",
    description: "HPC ve bulut ortamlarında ölçeklenebilir ve tekrarlanabilir biyoinformatik pipeline'ları için reaktif iş akışı çerçevesi.",
    url: "https://www.nextflow.io",
    tags: ["iş-akışı", "pipeline", "HPC"],
  },
  {
    title: "Snakemake",
    description: "Tekrarlanabilir ve ölçeklenebilir veri analizleri için Python tabanlı iş akışı yönetim sistemi.",
    url: "https://snakemake.readthedocs.io",
    tags: ["iş-akışı", "python", "pipeline"],
  },
  {
    title: "BLAST",
    description: "Temel Yerel Hizalama Arama Aracı — nükleotid veya protein dizileri ile veritabanı girdileri arasındaki benzerlik bölgelerini bulun.",
    url: "https://blast.ncbi.nlm.nih.gov",
    tags: ["dizi-arama", "hizalama"],
  },
  {
    title: "Cytoscape",
    description: "Biyolojik ağları ve yolları görselleştirmek ve analiz etmek için açık kaynaklı platform.",
    url: "https://cytoscape.org",
    tags: ["ağlar", "görselleştirme"],
  },
  {
    title: "IGV — Bütünleşik Genomik Görüntüleyici",
    description: "Genomik verilerin interaktif olarak keşfedilmesi için yüksek performanslı masaüstü ve web uygulaması.",
    url: "https://igv.org",
    tags: ["genom-tarayıcısı", "görselleştirme"],
  },
];

const community = [
  {
    title: "Biostars",
    description: "Biyoinformatik için soru-cevap forumu — göndermeden önce arayın, cevap büyük ihtimalle zaten oradadır.",
    url: "https://www.biostars.org",
    tags: ["forum", "soru-cevap"],
  },
  {
    title: "ISCB Öğrenci Konseyi",
    description: "ISCB bünyesindeki, hesaplamalı biyoloji öğrencileri ve genç araştırmacılar için uluslararası organizasyon.",
    url: "https://www.iscb.org/iscb-student-council",
    tags: ["topluluk", "ağ-oluşturma"],
  },
  {
    title: "RSG Türkiye GitHub",
    description: "Organizasyonumuzun GitHub sayfası — RSG Türkiye etkinliklerinden geçmiş eğitim materyalleri, scriptler ve kaynaklar.",
    url: "https://github.com/rsgturkey",
    tags: ["eğitim", "açık-kaynak"],
  },
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">Kaynaklar</h1>
      <p class="text-white/70 mt-2">Seçilmiş biyoinformatik öğrenme materyalleri, veritabanları ve araçlar</p>
    </div>
  </div>

  <section class="bg-white py-12">
    <div class="max-w-5xl mx-auto px-6 flex flex-col gap-14">

      <!-- Learning Resources -->
      <div>
        <h2 class="text-lg font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">Öğrenme Kaynakları</h2>
        <div class="flex flex-col">
          {learningResources.map((item) => (
            <div class="py-4 border-b border-border">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <a href={item.url} target="_blank" rel="noopener noreferrer"
                  class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title} →</a>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map((tag) => (
                  <span class="inline-block text-xs px-2 py-0.5 rounded bg-navy-light text-navy-mid border border-[#C4CEEA]">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Databases -->
      <div>
        <h2 class="text-lg font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">Veritabanları</h2>
        <div class="flex flex-col">
          {databases.map((item) => (
            <div class="py-4 border-b border-border">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <a href={item.url} target="_blank" rel="noopener noreferrer"
                  class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title} →</a>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map((tag) => (
                  <span class="inline-block text-xs px-2 py-0.5 rounded bg-navy-light text-navy-mid border border-[#C4CEEA]">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Tools & Software -->
      <div>
        <h2 class="text-lg font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">Araçlar ve Yazılımlar</h2>
        <div class="flex flex-col">
          {tools.map((item) => (
            <div class="py-4 border-b border-border">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <a href={item.url} target="_blank" rel="noopener noreferrer"
                  class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title} →</a>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map((tag) => (
                  <span class="inline-block text-xs px-2 py-0.5 rounded bg-navy-light text-navy-mid border border-[#C4CEEA]">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Community -->
      <div>
        <h2 class="text-lg font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">Topluluk</h2>
        <div class="flex flex-col">
          {community.map((item) => (
            <div class="py-4 border-b border-border">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <a href={item.url} target="_blank" rel="noopener noreferrer"
                  class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title} →</a>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map((tag) => (
                  <span class="inline-block text-xs px-2 py-0.5 rounded bg-navy-light text-navy-mid border border-[#C4CEEA]">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
