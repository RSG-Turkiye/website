---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';
import { getCollection } from 'astro:content';

const lang = 'tr';
const t = useTranslations(lang);
const pageTitle = "RSG Türkiye - Hesaplamalı Biyoloji Topluluğu";

const latestPosts = (await getCollection('blog', ({ id, data }) => id.startsWith('tr/') && !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Hero -->
  <section
    class="py-24 text-center bg-navy bg-cover bg-center"
    style="background-image: linear-gradient(rgba(26,39,68,0.78), rgba(26,39,68,0.88)), url('https://res.cloudinary.com/dyuf14ra5/image/upload/f_auto,q_auto/404A1947_mzkouu');"
  >
    <div class="max-w-2xl mx-auto px-6">
      <img src="/logo/rsgturkey_logo.png" alt="RSG Turkey Logo" width="72" height="72"
        class="mx-auto mb-6 rounded-lg bg-white p-1" />
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight">{t('hero.title')}</h1>
      <p class="text-white/75 text-lg leading-relaxed mb-8 max-w-xl mx-auto">{t('hero.description')}</p>
      <a href="/tr/join"
        class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium text-base hover:bg-red-hover transition-colors no-underline">
        {t('hero.joinCommunity')}
      </a>
    </div>
  </section>

  <!-- Mission + Stats -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 items-start">
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">{t('mission.title')}</h2>
          <p class="text-gray-600 leading-relaxed mb-3">{t('mission.description')}</p>
          <p class="text-gray-600 leading-relaxed">{t('mission.goal')}</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { n: '10+', label: t('stats.years') },
            { n: '50+', label: t('stats.members') },
            { n: '100+', label: t('stats.webinars') },
            { n: '15+', label: 'Sempozyum' },
          ].map(({ n, label }) => (
            <div class="text-center p-5 rounded-lg bg-navy-light border border-[#C4CEEA]">
              <span class="block text-3xl font-bold text-navy">{n}</span>
              <span class="block text-sm text-gray-500 mt-1">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Cards -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border border-b">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('contentCards.title')}</h2>
      <p class="text-gray-500 text-center max-w-lg mx-auto mb-10">{t('contentCards.subtitle')}</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-red-tint text-red mb-4">Webinar</span>
          <h3 class="text-base font-semibold text-navy mb-2">{t('contentCards.webinar.title')}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-4">{t('contentCards.webinar.description')}</p>
          <a href="/tr/webinars" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors">{t('contentCards.webinar.button')} →</a>
        </div>
        <!-- Events card (live calendar) -->
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors flex flex-col">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-red-tint text-red mb-4 self-start">Etkinlik</span>
          <div id="calendarCard" class="flex-1 flex flex-col">
            <div class="flex flex-col gap-2 animate-pulse">
              <div class="h-3 bg-navy/10 rounded w-3/4"></div>
              <div class="h-3 bg-navy/10 rounded w-1/2"></div>
            </div>
          </div>
        </div>
        <div class="bg-navy-light border border-[#C4CEEA] rounded-lg p-6 hover:border-navy-mid transition-colors flex flex-col">
          <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-red-tint text-red mb-4 self-start">Blog</span>
          {latestPosts[0] ? (
            <div class="flex-1 flex flex-col">
              <p class="text-xs text-gray-400 mb-1">
                {new Date(latestPosts[0].data.pubDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })}
                {latestPosts[0].data.author && <span> · {latestPosts[0].data.author}</span>}
              </p>
              <p class="text-sm font-semibold text-navy leading-snug mb-3">{latestPosts[0].data.title}</p>
              {latestPosts[0].data.description && (
                <p class="text-xs text-gray-500 leading-relaxed mb-4 flex-1">{latestPosts[0].data.description.slice(0, 100)}{latestPosts[0].data.description.length > 100 ? '…' : ''}</p>
              )}
              <a href={`/tr/blog/${latestPosts[0].id.replace(/^tr\//, '')}`} class="text-sm font-medium text-navy-mid hover:text-navy transition-colors mt-auto">
                Devamını Oku →
              </a>
            </div>
          ) : (
            <div class="flex-1 flex flex-col">
              <p class="text-sm text-gray-500 leading-relaxed mb-4 flex-1">{t('contentCards.blog.description')}</p>
              <a href="/tr/blog" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors">{t('contentCards.blog.button')} →</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Join CTA -->
  <section class="bg-white py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy mb-3">{t('cta.title')}</h2>
      <p class="text-gray-500 mb-6">{t('cta.description')}</p>
      <a href="/tr/join"
        class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium hover:bg-red-hover transition-colors no-underline">
        {t('cta.joinToday')}
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const CALENDAR_ID = 'itclr7bftj9s33vus9ct47d4v0@group.calendar.google.com';
  const API_KEY = import.meta.env.PUBLIC_GOOGLE_CALENDAR_API_KEY;
  const card = document.getElementById('calendarCard')!;

  const SOCIALS = [
    { label: 'Twitter', url: 'https://twitter.com/rsgturkey' },
    { label: 'Instagram', url: 'https://instagram.com/rsgturkey' },
    { label: 'LinkedIn', url: 'https://linkedin.com/company/rsgturkey' },
  ];

  function emptyState() {
    const links = SOCIALS.map(s =>
      `<a href="${s.url}" target="_blank" rel="noopener noreferrer"
        class="text-xs text-navy-mid hover:text-navy transition-colors no-underline">${s.label}</a>`
    ).join('<span class="text-gray-300">·</span>');
    card.innerHTML = `
      <p class="text-sm font-semibold text-navy mb-1">Yakında yeni etkinlikler planlanıyor!</p>
      <p class="text-xs text-gray-500 mb-4">Haberdar olmak için bizi takip edin</p>
      <div class="flex items-center gap-2 flex-wrap">${links}</div>`;
  }

  async function loadCalendar() {
    if (!API_KEY) { emptyState(); return; }

    const now = new Date().toISOString();
    const url = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(CALENDAR_ID)}/events?key=${API_KEY}&orderBy=startTime&singleEvents=true&timeMin=${now}&maxResults=2`;

    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items: any[] = data.items || [];

      if (items.length === 0) { emptyState(); return; }

      const html = items.map(ev => {
        const start = ev.start?.dateTime || ev.start?.date || '';
        const dateStr = start
          ? new Date(start).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })
          : '';
        return `
          <div class="mb-3 last:mb-0">
            <p class="text-sm font-semibold text-navy leading-snug">${ev.summary || ''}</p>
            ${dateStr ? `<p class="text-xs text-gray-400 mt-0.5">${dateStr}</p>` : ''}
          </div>`;
      }).join('');

      card.innerHTML = `${html}<a href="/tr/events" class="text-sm font-medium text-navy-mid hover:text-navy transition-colors mt-2 inline-block">Tüm etkinlikler →</a>`;
    } catch {
      emptyState();
    }
  }

  loadCalendar();
</script>
