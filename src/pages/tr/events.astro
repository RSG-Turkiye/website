---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'tr';
const t = useTranslations(lang);
const pageTitle = "Etkinlikler - RSG Türkiye";

const events = [
  {
    category: "Sempozyumlar",
    id: "symposiums",
    events: [
      { title: "Öğrenci Sempozyumu 2024", date: "2024", location: "Türkiye", description: "Hesaplamalı biyolojide araştırmacı ve öğrencileri bir araya getiren yıllık öğrenci sempozyumu.", status: "completed", type: "sempozyum" },
      { title: "Öğrenci Sempozyumu 2023", date: "2023", location: "Türkiye", description: "Araştırma sunumları ve ağ oluşturma fırsatları içeren yıllık öğrenci sempozyumu.", status: "completed", type: "sempozyum" },
    ]
  },
  {
    category: "Atölyeler",
    id: "workshops",
    events: [
      { title: "Tek Hücreli Analiz Atölyesi", date: "2024", location: "Türkiye", description: "Tek hücreli analiz teknikleri ve metodolojileri üzerine uygulamalı atölye.", status: "completed", type: "atölye" },
      { title: "Yapısal Biyoloji Atölyesi", date: "Aralık 2021", location: "Çevrimiçi", description: "Hesaplamalı Yapısal Biyolojiye Giriş — protein yapı belirleme, moleküler yuvalama ve moleküler dinamikler.", status: "completed", type: "atölye" },
      { title: "COVID-19 Araştırma Atölyesi", date: "2020", location: "Çevrimiçi", description: "COVID-19 araştırmalarına hesaplamalı yaklaşımlar üzerine atölye.", status: "completed", type: "atölye" },
    ]
  },
  {
    category: "Yaklaşan Etkinlikler",
    id: "upcoming",
    events: [
      { title: "Yıllık Sempozyum 2025", date: "TBD 2025", location: "Türkiye", description: "Türkiye'deki hesaplamalı biyoloji topluluğunu bir araya getiren yıllık sempozyumumuz.", status: "upcoming", type: "sempozyum" },
      { title: "Biyoinformatik Araçları Atölyesi", date: "TBD 2025", location: "TBD", description: "Popüler biyoinformatik araçlar ve pipeline'lar üzerine uygulamalı atölye.", status: "upcoming", type: "atölye" },
    ]
  }
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('events.title')}</h1>
      <p class="text-white/70 mt-2">{t('events.subtitle')}</p>
    </div>
  </div>

  <!-- Live Calendar Section -->
  <section class="bg-[#F7F7F6] py-12 border-b border-border">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-lg font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">
        Takvimden Yaklaşan Etkinlikler
      </h2>
      <div id="calendarEvents">
        <p class="text-sm text-gray-400 italic">Etkinlikler yükleniyor…</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      {events.map((category) => (
        <div class="mb-12" id={category.id}>
          <h2 class="text-xl font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">{category.category}</h2>
          <div class="flex flex-col">
            {category.events.map((event) => (
              <div class="grid grid-cols-1 md:grid-cols-[160px_1fr] gap-4 py-5 border-b border-border items-start">
                <div class="flex flex-col">
                  <span class="text-sm font-medium text-navy">{event.date}</span>
                  <span class="text-xs text-gray-400">{event.location}</span>
                </div>
                <div>
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <strong class="text-navy">{event.title}</strong>
                    <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded ${event.status === 'upcoming' ? 'bg-red-tint text-red' : 'bg-navy-light text-navy-mid'}`}>
                      {event.status === 'upcoming' ? t('events.status.upcoming') : t('events.status.completed')}
                    </span>
                    <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{event.type}</span>
                  </div>
                  <p class="text-sm text-gray-500 leading-relaxed mb-2">{event.description}</p>
                  {event.status === 'upcoming' && (
                    <a href="mailto:turkey.rsg@gmail.com" class="inline-flex items-center px-3 py-1.5 rounded bg-red text-white text-xs font-medium hover:bg-red-hover transition-colors no-underline">
                      {t('events.register')}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  const CALENDAR_ID = 'itclr7bftj9s33vus9ct47d4v0@group.calendar.google.com';
  const API_KEY = import.meta.env.PUBLIC_GOOGLE_CALENDAR_API_KEY;

  const container = document.getElementById('calendarEvents')!;

  async function loadCalendar() {
    if (!API_KEY) {
      container.innerHTML = '';
      return;
    }

    const now = new Date().toISOString();
    const url = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(CALENDAR_ID)}/events?key=${API_KEY}&orderBy=startTime&singleEvents=true&timeMin=${now}&maxResults=10`;

    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const items: any[] = data.items || [];

      if (items.length === 0) {
        container.innerHTML = '<p class="text-sm text-gray-400 italic">Yaklaşan etkinlik bulunamadı.</p>';
        return;
      }

      container.innerHTML = items.map(event => {
        const start = event.start?.dateTime || event.start?.date || '';
        const dateObj = start ? new Date(start) : null;
        const dateStr = dateObj
          ? dateObj.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })
          : '';
        const timeStr = event.start?.dateTime
          ? dateObj!.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' })
          : '';
        const location = event.location || '';
        const url = event.htmlLink || '#';

        return `
          <div class="grid grid-cols-1 md:grid-cols-[160px_1fr] gap-4 py-5 border-b border-border items-start">
            <div class="flex flex-col">
              <span class="text-sm font-medium text-navy">${dateStr}</span>
              ${timeStr ? `<span class="text-xs text-gray-400">${timeStr}</span>` : ''}
              ${location ? `<span class="text-xs text-gray-400 mt-0.5">${location}</span>` : ''}
            </div>
            <div>
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <strong class="text-navy">${event.summary || '(Başlık yok)'}</strong>
                <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-red-tint text-red">Yaklaşan</span>
              </div>
              ${event.description ? `<p class="text-sm text-gray-500 leading-relaxed mb-2">${event.description.replace(/<[^>]*>/g, '').slice(0, 200)}</p>` : ''}
              <a href="${url}" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center px-3 py-1.5 rounded bg-red text-white text-xs font-medium hover:bg-red-hover transition-colors no-underline">
                Takvime Ekle →
              </a>
            </div>
          </div>`;
      }).join('');
    } catch (err) {
      container.innerHTML = '<p class="text-sm text-gray-400 italic">Etkinlikler yüklenemedi.</p>';
    }
  }

  loadCalendar();
</script>
