---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'tr';
const t = useTranslations(lang);
const pageTitle = "İletişim - RSG Türkiye";

const faqs = [
  { q: "RSG Türkiye'ye nasıl katılabilirim?", a: "Hesaplamalı biyoloji ve biyoinformatik ile ilgilenen herkes topluluğumuza katılabilir. Etkinliklerimize, webinarlarımıza katılarak veya doğrudan bize ulaşarak başlayabilirsiniz." },
  { q: "Etkinlikleriniz uluslararası katılımcılara açık mı?", a: "Evet! Etkinliklerimizin çoğu, özellikle webinarlar, uluslararası katılımcılara açıktır." },
  { q: "Yaklaşan etkinliklerden nasıl haberdar olabilirim?", a: "Bültenimize abone olarak, sosyal medyada bizi takip ederek veya web sitemizi düzenli olarak kontrol ederek güncel kalabilirsiniz." },
  { q: "Webinar veya atölye konusu önerebilir miyim?", a: "Kesinlikle! Webinar konuları ve atölye temaları için önerilerinizi bekliyoruz. Lütfen teklifinizle birlikte bize ulaşın." },
];
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('contact.title')}</h1>
      <p class="text-white/70 mt-2">{t('contact.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 items-start">

        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">Bize Mesaj Gönderin</h2>
          <form id="contactForm" class="flex flex-col gap-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-medium text-navy mb-1">Ad *</label>
                <input type="text" id="firstName" name="firstName" required class="input-field" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-navy mb-1">Soyad *</label>
                <input type="text" id="lastName" name="lastName" required class="input-field" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-1">{t('contact.form.email')} *</label>
                <input type="email" id="email" name="email" required class="input-field" />
              </div>
              <div>
                <label for="institution" class="block text-sm font-medium text-navy mb-1">Kurum</label>
                <input type="text" id="institution" name="institution" class="input-field" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-navy mb-1">{t('contact.form.subject')} *</label>
              <select id="subject" name="subject" required class="input-field">
                <option value="">Konu seçin...</option>
                <option value="general">Genel Soru</option>
                <option value="membership">Üyelik Sorusu</option>
                <option value="events">Etkinlik Bilgisi</option>
                <option value="webinars">Webinar Kaydı</option>
                <option value="collaboration">İşbirliği Teklifi</option>
                <option value="other">Diğer</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-1">{t('contact.form.message')} *</label>
              <textarea id="message" name="message" rows="5" required class="input-field resize-y"></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input type="checkbox" id="newsletter" name="newsletter" class="mt-0.5 accent-navy" />
              <label for="newsletter" class="text-sm text-gray-600">Etkinlik ve webinarlar hakkında güncellemeler almak için bültenimize abone olun</label>
            </div>
            <div>
              <button type="submit" class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium hover:bg-red-hover transition-colors">
                {t('contact.form.send')}
              </button>
            </div>
            <div id="contactFormMessage"></div>
          </form>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">{t('contact.info.title')}</h2>
          <div class="flex flex-col gap-6">
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">{t('contact.info.email')}</h4>
              <a href="mailto:turkey.rsg@gmail.com" class="text-navy-mid hover:text-navy transition-colors">turkey.rsg@gmail.com</a>
            </div>
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">{t('contact.info.social')}</h4>
              <ul class="flex flex-col gap-1.5">
                {['Twitter', 'LinkedIn', 'GitHub', 'YouTube', 'Instagram'].map((platform) => (
                  <li>
                    <a href={
                        platform === 'YouTube' ? 'https://www.youtube.com/@RSG-Turkiye' :
                        platform === 'LinkedIn' ? 'https://linkedin.com/company/rsgturkey' :
                        `https://${platform.toLowerCase()}.com/rsgturkey`
                      }
                      target="_blank" rel="noopener noreferrer"
                      class="text-sm text-navy-mid hover:text-navy transition-colors">{platform}</a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-8">Sıkça Sorulan Sorular</h2>
      <div class="flex flex-col gap-2">
        {faqs.map((faq) => (
          <div class="bg-white border border-border rounded-lg overflow-hidden">
            <button
              class="w-full flex justify-between items-center px-5 py-4 text-left text-sm font-medium text-navy hover:bg-navy-light transition-colors"
              aria-expanded="false"
              onclick="const b=this.nextElementSibling;const open=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!open));b.style.display=open?'none':'block'"
            >
              {faq.q}
              <span class="text-xl font-light text-gray-400 ml-4 shrink-0">+</span>
            </button>
            <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed" style="display:none;">{faq.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @reference "../../styles/global.css";
  .input-field {
    @apply w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors bg-white;
  }
</style>

<script>
  const contactForm = document.getElementById('contactForm') as HTMLFormElement;
  const msgDiv = document.getElementById('contactFormMessage');
  if (contactForm && msgDiv) {
    contactForm.addEventListener('submit', function(e) {
      e.preventDefault();
      msgDiv.className = 'mt-2 p-3 rounded bg-green-50 text-green-800 border border-green-200 text-sm';
      msgDiv.textContent = 'Mesajınız için teşekkürler! En kısa sürede size döneceğiz.';
      this.reset();
    });
  }
</script>
