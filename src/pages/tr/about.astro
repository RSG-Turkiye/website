---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommitteeCard from '../../layouts/CommitteeCard.astro';
import { getCommittees } from '../../data/committees';
import { useTranslations } from '../../i18n/ui';

const lang = 'tr';
const t = useTranslations(lang);
const pageTitle = "Hakkımızda - RSG Türkiye";
const committees = getCommittees(lang);
---

<BaseLayout pageTitle={pageTitle}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('about.title')}</h1>
      <p class="text-white/70 mt-2">{t('about.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">{t('about.whoWeAre.title')}</h2>
          <p class="text-gray-600 leading-relaxed mb-3">{t('about.whoWeAre.description')}</p>
          <p class="text-gray-600 leading-relaxed">{t('about.whoWeAre.detail')}</p>
        </div>
        <div>
          <img src="/images/foraboutpage.jpeg" alt="RSG Turkey Community" class="w-full rounded-lg border border-border" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F7F7F6] py-16 border-t border-border border-b">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('about.whatWeDo.title')}</h2>
      <p class="text-gray-500 text-center max-w-xl mx-auto mb-10">{t('about.whatWeDo.subtitle')}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { title: t('about.symposiums.title'), desc: t('about.symposiums.description') },
          { title: t('about.webinars.title'), desc: t('about.webinars.description') },
          { title: t('about.presentations.title'), desc: t('about.presentations.description') },
          { title: 'Kariyer Gelişimi', desc: 'Öğrenciler ve erken kariyer araştırmacıları için eğitim ve iş fırsatlarını genişletmek amacıyla kariyer fuarları ve pazarları.' },
          { title: 'Uluslararası İşbirliği', desc: 'ISCB Öğrenci Konseyi aracılığıyla Türk topluluğu ile uluslararası meslektaşlar arasında köprüler kurmak.' },
          { title: 'Eğitim Kaynakları', desc: 'Hesaplamalı biyoloji topluluğu için eğitim materyalleri, araçlar ve kaynaklar sağlamak.' },
        ].map(({ title, desc }) => (
          <div class="bg-white border border-[#C4CEEA] rounded-lg p-5 hover:border-navy-mid transition-colors">
            <h4 class="font-semibold text-navy mb-2">{title}</h4>
            <p class="text-sm text-gray-500 leading-relaxed m-0">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">ISCB Öğrenci Konseyi Üyeliği</h2>
          <p class="text-gray-600 leading-relaxed mb-3">Uluslararası Hesaplamalı Biyoloji Derneği (ISCB) Öğrenci Konseyi üyesi olmaktan gurur duyuyoruz.</p>
          <p class="text-gray-600 leading-relaxed mb-4">ISCB Öğrenci Konseyi, dünya çapında hesaplamalı biyoloji ve biyoinformatik alanlarında çalışan öğrenci ve doktora sonrası araştırmacılar arasında iletişim ve etkileşim için çerçeve sağlar.</p>
          <ul class="space-y-2">
            {['Uluslararası konferans ve etkinliklere erişim', 'Küresel araştırmacılarla ağ oluşturma fırsatları', 'Eğitim kaynakları ve eğitim programları', "Diğer RSG'lerle işbirliği fırsatları"].map((item) => (
              <li class="flex items-start gap-2 text-gray-600 text-sm">
                <span class="text-navy font-bold mt-0.5">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="text-center p-8 bg-navy-light border border-[#C4CEEA] rounded-lg">
          <img src="/logo/iscb-logo.png" alt="ISCB Student Council" class="max-h-16 mx-auto mb-4" />
          <h4 class="font-semibold text-navy mb-1">ISCB Öğrenci Konseyi</h4>
          <p class="text-sm text-gray-500 mb-4">Uluslararası Hesaplamalı Biyoloji Derneği</p>
          <a href="https://www.iscb.org/iscb-student-council" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded border border-navy text-navy text-sm font-medium hover:bg-navy hover:text-white transition-colors no-underline">
            ISCB Öğrenci Konseyi'ni Ziyaret Et
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('about.committees.title')}</h2>
      <p class="text-gray-500 text-center max-w-xl mx-auto mb-10">{t('about.committees.subtitle')}</p>
      <div class="flex flex-col gap-6">
        {committees.map((committee) => (
          <CommitteeCard name={committee.name} description={committee.description} members={committee.members} />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
