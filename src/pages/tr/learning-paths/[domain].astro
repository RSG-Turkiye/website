---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResourceCard from '../../../components/learning-paths/ResourceCard.astro';
import ProgressBar from '../../../components/learning-paths/ProgressBar.astro';
import LevelSwitcher from '../../../components/learning-paths/LevelSwitcher.astro';

export async function getStaticPaths() {
  const allDomains = await getCollection('lpDomains');
  const domains = allDomains.filter(d => d.id.startsWith('tr/'));
  return domains.map(domain => ({
    params: { domain: domain.id.slice(3) }, // 'tr/genomics' → 'genomics'
    props: { domain, domainSlug: domain.id.slice(3) },
  }));
}

const { domain, domainSlug } = Astro.props;
const { name, emoji, tagline, goDeeper } = domain.data;

// Load all level content for this domain (TR only)
const allLevelEntries = await getCollection('lpLevels', e => e.data.domain === domainSlug && e.id.startsWith('tr/'));

const LEVEL_ORDER = ['explorer', 'practitioner', 'researcher', 'specialist'] as const;
type LevelId = typeof LEVEL_ORDER[number];

const LEVEL_LABELS: Record<LevelId, string> = {
  explorer:     'Keşifçi',
  practitioner: 'Uygulayıcı',
  researcher:   'Araştırmacı',
  specialist:   'Uzman',
};

const SECTION_LABELS: Record<string, string> = {
  foundations: 'Temel Kaynaklar',
  toolkit:     'Araçlar',
  webinars:    'RSG Türkiye Oturumları',
  papers:      'Önemli Makaleler',
};

const levelMap = new Map(allLevelEntries.map(e => [e.data.level, e.data]));

const levels = LEVEL_ORDER.map(id => ({
  id,
  label: LEVEL_LABELS[id],
  exists: levelMap.has(id),
  content: levelMap.get(id) ?? null,
}));

const defaultLevel = levels.find(l => l.exists)?.id ?? 'explorer';

const levelResourceIds = levels.map(level => {
  if (!level.content) return [];
  return level.content.sections.map(section =>
    section.resources.map((_, ri) => `tr-${domainSlug}-${level.id}-${section.type}-${ri}`)
  );
});

const levelTotals = levels.map((level, li) =>
  levelResourceIds[li].flat().length
);

const levelsForScript = levels.map((level, li) => ({
  id: level.id,
  exists: level.exists,
  resourceIds: levelResourceIds[li].flat(),
  total: levelTotals[li],
}));
---

<BaseLayout
  pageTitle={`${name} — Öğrenme Yolu — RSG Türkiye`}
  description={tagline}>

  <!-- ── Hero ── -->
  <div class="bg-navy py-14 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, white 0, white 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <a href="/tr/learning-paths" class="inline-flex items-center gap-1.5 text-xs text-white/50 hover:text-white/80 mb-5 no-underline transition-colors">
        ← Öğrenme Yolları
      </a>
      <div class="text-5xl mb-4">{emoji}</div>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">{name}</h1>
      <p class="text-white/70 text-base leading-relaxed max-w-xl mx-auto">{tagline}</p>
    </div>
  </div>

  <!-- ── Level switcher ── -->
  <LevelSwitcher
    levels={levels.map(l => ({ id: l.id, label: l.label, exists: l.exists }))}
    activeLevel={defaultLevel}
    comingSoonText="(yakında)"
  />

  <!-- ── Progress bar ── -->
  <ProgressBar accentColor="navy" progressLabel="İlerlemeniz" resetLabel="Sıfırla" />

  <!-- ── Level sections ── -->
  <div class="bg-white py-12">
    <div class="max-w-4xl mx-auto px-6">

      {levels.map((level, li) => level.exists && level.content && (
        <div
          id={`level-${level.id}`}
          class:list={['level-section', level.id !== defaultLevel && 'hidden']}>

          <!-- Orientation + prerequisites -->
          <div class="mb-10">
            <p class="text-base text-gray-600 leading-relaxed mb-4">{level.content.orientation}</p>
            {level.content.prerequisites && level.content.prerequisites.length > 0 && (
              <div class="bg-navy-light border border-[#C4CEEA] rounded-xl px-5 py-4">
                <p class="text-xs font-bold tracking-widest uppercase text-navy-mid mb-2">Bilinmesi gerekenler</p>
                <ul class="space-y-1">
                  {level.content.prerequisites.map(p => (
                    <li class="flex items-start gap-2 text-sm text-navy">
                      <span class="text-navy-mid mt-0.5 shrink-0">✓</span>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          <!-- Sections -->
          {level.content.sections.map((section, si) => (
            <div class="mb-10">
              <h3 class="text-xs font-bold tracking-widest uppercase text-navy-mid mb-4 flex items-center gap-2">
                {SECTION_LABELS[section.type] ?? section.type}
                <span id={`section-count-${level.id}-${section.type}`} class="text-gray-300 font-normal normal-case tracking-normal"></span>
              </h3>
              <div class="flex flex-col gap-3">
                {section.resources.map((res, ri) => (
                  <ResourceCard
                    resource={res}
                    resourceId={levelResourceIds[li][si][ri]}
                    lang="tr"
                  />
                ))}
              </div>
            </div>
          ))}

          <!-- What's next bridge -->
          {(() => {
            const nextLevel = levels.find((l, idx) => idx > li && l.exists);
            return nextLevel ? (
              <div class="mt-8 mb-12 p-5 rounded-xl bg-navy-light border border-[#C4CEEA] flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs font-bold tracking-widest uppercase text-navy-mid mb-1">Hazır olduğunuzda</p>
                  <p class="text-sm text-navy"><strong>{nextLevel.label}</strong> seviyesine devam edin</p>
                </div>
                <button
                  class="level-tab shrink-0 text-sm font-semibold text-white bg-navy hover:bg-navy-mid transition-colors px-4 py-2 rounded-lg"
                  data-level={nextLevel.id}>
                  {nextLevel.label} →
                </button>
              </div>
            ) : null;
          })()}

        </div>
      ))}

      <!-- Go Deeper -->
      {goDeeper && goDeeper.length > 0 && (
        <div class="mt-8 rounded-2xl border border-dashed border-navy-mid bg-navy-light p-6">
          <p class="text-xs font-bold tracking-widest uppercase text-navy-mid mb-4">Daha Derine İnin →</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {goDeeper.map(item => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-3 p-3 rounded-lg bg-white border border-border hover:border-navy-mid hover:shadow-sm transition-all duration-150 no-underline">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-navy group-hover:text-navy-mid transition-colors leading-tight">
                    {item.title} <span class="text-gray-300 font-normal text-xs">↗</span>
                  </p>
                  <p class="text-xs text-gray-500 mt-0.5">{item.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-12 bg-navy rounded-2xl px-8 py-10 text-center">
        <h3 class="text-white font-bold text-lg mb-2">Bir sonraki eklemeleri şekillendirmek ister misiniz?</h3>
        <p class="text-white/60 text-sm mb-6 max-w-md mx-auto">
          Öğrenme yollarını düzenlemek topluluk çabasıdır. RSG Türkiye'ye katılın ve bir sonraki seviyeyi birlikte oluşturun.
        </p>
        <a href="/join" class="inline-block bg-red hover:bg-red-hover text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors no-underline">
          RSG Türkiye'ye Katıl →
        </a>
      </div>

    </div>
  </div>

</BaseLayout>

<script define:vars={{ domainId: domainSlug, levelsForScript, defaultLevel }}>
  const STORAGE_PREFIX = 'rsg-lp-tr-';

  function storageKey(levelId) {
    return `${STORAGE_PREFIX}${domainId}-${levelId}-v1`;
  }

  let currentLevel = defaultLevel;

  const urlParam = new URLSearchParams(window.location.search).get('level');
  const validLevel = levelsForScript.find(l => l.exists && l.id === urlParam);
  if (validLevel) {
    currentLevel = validLevel.id;
    document.querySelectorAll('.level-section').forEach(el => {
      el.classList.toggle('hidden', el.id !== `level-${currentLevel}`);
    });
  }

  function switchLevel(levelId) {
    if (levelId === currentLevel) return;
    const target = levelsForScript.find(l => l.id === levelId);
    if (!target || !target.exists) return;

    document.querySelectorAll('.level-section').forEach(el => {
      el.classList.toggle('hidden', el.id !== `level-${levelId}`);
    });

    document.querySelectorAll('.level-tab').forEach(btn => {
      const isActive = btn.dataset.level === levelId;
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('text-navy', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-gray-400', !isActive);
    });

    currentLevel = levelId;
    history.replaceState(null, '', `?level=${levelId}`);
    updateProgress();
  }

  document.querySelectorAll('.level-tab').forEach(btn => {
    btn.addEventListener('click', () => switchLevel(btn.dataset.level));
  });

  function getActiveIds() {
    const level = levelsForScript.find(l => l.id === currentLevel);
    return level ? level.resourceIds : [];
  }

  function loadSaved(levelId) {
    try { return JSON.parse(localStorage.getItem(storageKey(levelId)) || '{}'); } catch { return {}; }
  }

  function saveState(levelId) {
    const ids = levelsForScript.find(l => l.id === levelId)?.resourceIds ?? [];
    const state = {};
    ids.forEach(id => {
      const cb = document.getElementById(id);
      if (cb) state[id] = cb.checked;
    });
    localStorage.setItem(storageKey(levelId), JSON.stringify(state));
  }

  levelsForScript.forEach(level => {
    if (!level.exists) return;
    const saved = loadSaved(level.id);
    level.resourceIds.forEach(id => {
      const cb = document.getElementById(id);
      if (cb && saved[id]) cb.checked = true;
    });
  });

  function updateProgress() {
    const activeIds = getActiveIds();
    const cbs = activeIds.map(id => document.getElementById(id)).filter(Boolean);
    const done = cbs.filter(cb => cb.checked).length;
    const total = cbs.length;
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;

    const fill = document.getElementById('progressFill');
    const label = document.getElementById('progressLabel');
    if (fill) fill.style.width = pct + '%';
    if (label) label.textContent = total > 0 ? `${done} / ${total}` : '—';
  }

  levelsForScript.forEach(level => {
    if (!level.exists) return;
    level.resourceIds.forEach(id => {
      const cb = document.getElementById(id);
      cb?.addEventListener('change', () => {
        saveState(level.id);
        if (level.id === currentLevel) updateProgress();
      });
    });
  });

  document.getElementById('resetBtn')?.addEventListener('click', () => {
    if (!confirm(`${currentLevel} seviyesi ilerlemenizi sıfırlansın mı?`)) return;
    const activeIds = getActiveIds();
    activeIds.forEach(id => {
      const cb = document.getElementById(id);
      if (cb) cb.checked = false;
    });
    localStorage.removeItem(storageKey(currentLevel));
    updateProgress();
  });

  updateProgress();

  // ── Server sync (logged-in users only) ────────────────────────
  (async () => {
    const authData = await fetch('/api/me').then(r => r.json()).catch(() => null);
    if (!authData?.user) return;

    const progData = await fetch('/api/progress').then(r => r.json()).catch(() => null);
    if (!progData) return;
    const serverCompleted = new Set(progData.completed || []);

    const allIds = levelsForScript.flatMap(l => l.exists ? l.resourceIds : []);

    const toSync = allIds
      .filter(id => {
        const cb = document.getElementById(id);
        return cb && cb.checked && !serverCompleted.has(id);
      })
      .map(id => ({ resource_id: id, completed: true }));

    let changed = false;
    serverCompleted.forEach(id => {
      const cb = document.getElementById(id);
      if (cb && !cb.checked) { cb.checked = true; changed = true; }
    });
    if (changed) {
      levelsForScript.forEach(level => { if (level.exists) saveState(level.id); });
      updateProgress();
    }

    if (toSync.length > 0) {
      fetch('/api/progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: toSync }),
      });
    }

    allIds.forEach(id => {
      const cb = document.getElementById(id);
      cb?.addEventListener('change', () => {
        fetch('/api/progress', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ resource_id: id, completed: cb.checked }),
        });
      });
    });
  })();
</script>
