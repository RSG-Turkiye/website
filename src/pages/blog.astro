---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allBlogPosts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft && data.type !== 'webinar');
const sortedPosts = allBlogPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const pageTitle = "Blog - RSG Turkey";
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Page Header -->
  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('blog.title')}</h1>
      <p class="text-white/70 mt-2">{t('blog.subtitle')}</p>
    </div>
  </div>

  <section class="bg-white py-10">
    <div class="max-w-3xl mx-auto px-6">

      <!-- Search -->
      <div class="mb-8">
        <input
          type="text"
          id="searchPosts"
          placeholder={t('blog.search')}
          class="w-full border border-border rounded-md px-4 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors"
        />
      </div>

      <!-- Featured posts (top 2) -->
      {sortedPosts.slice(0, 2).map((post: any) => (
        <article class="post-item py-5 border-b border-border"
          data-title={post.data.title}
          data-description={post.data.description || ''}>
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-2">
            <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            {post.data.author && <span>{post.data.author}</span>}
          </div>
          <h2 class="text-lg font-semibold mb-1">
            <a href={`/blog/${post.id}`} class="text-navy hover:text-navy-mid transition-colors">{post.data.title}</a>
          </h2>
          {post.data.description && <p class="text-sm text-gray-500 leading-relaxed mb-2">{post.data.description}</p>}
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}

      <!-- Remaining posts -->
      <div id="postsGrid">
        {sortedPosts.slice(2).map((post: any) => (
          <article class="post-item py-4 border-b border-border"
            data-title={post.data.title}
            data-description={post.data.description || ''}>
            <div class="flex items-center gap-3 text-xs text-gray-400 mb-1">
              <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              {post.data.author && <span>{post.data.author}</span>}
            </div>
            <h3 class="text-base font-semibold mb-1">
              <a href={`/blog/${post.id}`} class="text-navy hover:text-navy-mid transition-colors">{post.data.title}</a>
            </h3>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchPosts') as HTMLInputElement;
    if (!searchInput) return;
    searchInput.addEventListener('input', function() {
      const term = this.value.toLowerCase();
      document.querySelectorAll<HTMLElement>('.post-item').forEach(item => {
        const title = (item.dataset.title || '').toLowerCase();
        const desc = (item.dataset.description || '').toLowerCase();
        item.style.display = (title.includes(term) || desc.includes(term)) ? '' : 'none';
      });
    });
  });
</script>
