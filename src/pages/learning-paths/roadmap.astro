---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/learning-paths/ResourceCard.astro';
import ProgressBar from '../../components/learning-paths/ProgressBar.astro';

const allStages = await getCollection('lpRoadmap');
const stages = allStages.filter(s => s.id.startsWith('en/')).sort((a, b) => a.data.number - b.data.number);

const totalResources = stages.reduce((sum, s) => sum + s.data.resources.length, 0);

// Pre-compute resource IDs exactly as the client script will
const stageResourceIds = stages.map(stage =>
  stage.data.resources.map((_, ri) => `roadmap-${stage.data.number}-${ri}`)
);
---

<BaseLayout
  pageTitle="Beginner Roadmap — RSG Turkiye"
  description="8 stages from zero to your first bioinformatics project. No prior experience required.">

  <!-- ── Hero ── -->
  <div class="bg-navy py-14 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, white 0, white 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
    <div class="relative max-w-3xl mx-auto px-6">
      <a href="/learning-paths" class="inline-flex items-center gap-1.5 text-xs text-white/50 hover:text-white/80 mb-5 no-underline transition-colors">
        ← Learning Paths
      </a>
      <div class="inline-block text-xs font-semibold tracking-widest uppercase text-red-tint bg-red/20 px-3 py-1 rounded-full mb-4">Start Here</div>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">Your path into bioinformatics</h1>
      <p class="text-white/70 text-base leading-relaxed max-w-xl mx-auto">
        {stages.length} stages · {totalResources} resources. Works for biology backgrounds, CS backgrounds, and everything in between.
        Your progress is saved automatically in your browser.
      </p>
    </div>
  </div>

  <!-- ── Progress bar ── -->
  <ProgressBar accentColor="red" />

  <!-- ── Roadmap ── -->
  <div class="bg-white py-12">
    <div class="max-w-4xl mx-auto px-6">
      <div class="relative">

        <!-- Vertical connecting line -->
        <div class="absolute left-6 top-8 bottom-8 w-0.5 bg-gradient-to-b from-red via-navy-light to-transparent hidden md:block"></div>

        <div class="flex flex-col gap-0">
          {stages.map((stage, si) => (
            <div id={stage.id} class="relative flex gap-6 pb-12">

              <!-- Stage circle -->
              <div class="relative shrink-0 z-10">
                <div class={`w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold text-white shadow-md ${stage.data.color === 'red' ? 'bg-red' : 'bg-navy'}`}>
                  {stage.data.emoji}
                </div>
              </div>

              <!-- Stage content -->
              <div class="flex-1 min-w-0 pt-1">
                <div class="flex items-baseline gap-3 mb-1">
                  <span class={`text-xs font-bold tracking-widest uppercase ${stage.data.color === 'red' ? 'text-red' : 'text-navy-mid'}`}>
                    Stage {stage.data.number}
                  </span>
                  <span id={`stage-count-${stage.id}`} class="text-xs text-gray-300 tabular-nums"></span>
                </div>
                <h2 class="text-xl font-bold text-navy mb-1">{stage.data.title}</h2>
                <p class="text-sm text-gray-500 leading-relaxed mb-5">{stage.data.subtitle}</p>

                <!-- Resources -->
                <div class="flex flex-col gap-3">
                  {stage.data.resources.map((res, ri) => (
                    <ResourceCard
                      resource={res}
                      resourceId={stageResourceIds[si][ri]}
                    />
                  ))}
                </div>

                <!-- Stage complete badge -->
                <div id={`stage-done-${stage.id}`} class="hidden mt-4 inline-flex items-center gap-2 text-xs font-semibold text-green-700 bg-green-50 border border-green-200 px-3 py-1.5 rounded-full">
                  <span>✓</span> Stage complete
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Final CTA -->
        <div class="relative flex gap-6">
          <div class="relative shrink-0 z-10">
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-green-500 shadow-md">🎉</div>
          </div>
          <div class="flex-1 bg-navy rounded-2xl p-8 mt-1">
            <h3 class="text-white font-bold text-lg mb-2">You made it.</h3>
            <p class="text-white/60 text-sm leading-relaxed mb-5">
              If you worked through this roadmap, you have the foundations to contribute to real research.
              Pick a domain below and go deep — or join RSG Turkey and work on real problems with people at all stages.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/join" class="inline-block bg-red hover:bg-red-hover text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors no-underline">
                Join RSG Turkey →
              </a>
              <a href="/learning-paths" class="inline-block bg-white/10 hover:bg-white/20 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors no-underline">
                Browse domains →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<script define:vars={{ stageResourceIds, stages: stages.map(s => ({ id: s.id, resourceCount: s.data.resources.length })) }}>
  const STORAGE_KEY = 'rsg-lp-roadmap-v1';

  // Flatten all resource IDs
  const allIds = stageResourceIds.flat();

  // Load saved progress
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}

  const checkboxes = allIds.map(id => document.getElementById(id)).filter(Boolean);

  // Restore state
  checkboxes.forEach(cb => { if (saved[cb.id]) cb.checked = true; });

  function updateProgress() {
    const done = checkboxes.filter(cb => cb.checked).length;
    const total = allIds.length;
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;

    const fill = document.getElementById('progressFill');
    const label = document.getElementById('progressLabel');
    if (fill) fill.style.width = pct + '%';
    if (label) label.textContent = `${done} / ${total}`;

    // Stage completion badges
    let offset = 0;
    stages.forEach(stage => {
      const stageCbs = stageResourceIds[stages.indexOf(stage)]
        .map(id => document.getElementById(id)).filter(Boolean);
      const doneCount = stageCbs.filter(cb => cb.checked).length;
      const allDone = stageCbs.length > 0 && doneCount === stageCbs.length;
      const badge = document.getElementById(`stage-done-${stage.id}`);
      const counter = document.getElementById(`stage-count-${stage.id}`);
      if (badge) badge.classList.toggle('hidden', !allDone);
      if (counter) counter.textContent = doneCount > 0 ? `${doneCount}/${stageCbs.length} done` : '';
    });

    // Persist
    const state = {};
    checkboxes.forEach(cb => { state[cb.id] = cb.checked; });
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateProgress));

  document.getElementById('resetBtn')?.addEventListener('click', () => {
    if (!confirm('Reset all roadmap progress?')) return;
    checkboxes.forEach(cb => cb.checked = false);
    localStorage.removeItem(STORAGE_KEY);
    updateProgress();
  });

  updateProgress();

  // ── Server sync (logged-in users only) ────────────────────────
  (async () => {
    const authData = await fetch('/api/me').then(r => r.json()).catch(() => null);
    if (!authData?.user) return;

    const progData = await fetch('/api/progress').then(r => r.json()).catch(() => null);
    if (!progData) return;
    const serverCompleted = new Set(progData.completed || []);

    // Items completed locally but missing on server → sync up
    const toSync = checkboxes
      .filter(cb => cb.checked && !serverCompleted.has(cb.id))
      .map(cb => ({ resource_id: cb.id, completed: true }));

    // Items on server but not checked locally → restore them
    let changed = false;
    serverCompleted.forEach(id => {
      const cb = document.getElementById(id);
      if (cb && !cb.checked) { cb.checked = true; changed = true; }
    });
    if (changed) updateProgress();

    if (toSync.length > 0) {
      fetch('/api/progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: toSync }),
      });
    }

    // Wire up real-time sync on future changes
    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        fetch('/api/progress', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ resource_id: cb.id, completed: cb.checked }),
        });
      });
    });
  })();
</script>
