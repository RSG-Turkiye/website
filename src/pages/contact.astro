---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "Contact Us - RSG Turkey";

const faqs = [
  {
    q: lang === 'tr' ? "RSG Türkiye'ye nasıl katılabilirim?" : "How can I join RSG Turkey?",
    a: lang === 'tr'
      ? "Hesaplamalı biyoloji ve biyoinformatik ile ilgilenen herkes topluluğumuza katılabilir. Etkinliklerimize, webinarlarımıza katılarak veya doğrudan bize ulaşarak başlayabilirsiniz."
      : "Anyone interested in computational biology and bioinformatics is welcome to join. You can start by attending our events, webinars, or contacting us directly.",
  },
  {
    q: lang === 'tr' ? "Etkinlikleriniz uluslararası katılımcılara açık mı?" : "Are your events open to international participants?",
    a: lang === 'tr'
      ? "Evet! Etkinliklerimizin çoğu, özellikle webinarlar, uluslararası katılımcılara açıktır."
      : "Yes! Many of our events, especially webinars, are open to international participants. We welcome collaboration and participation from researchers worldwide.",
  },
  {
    q: lang === 'tr' ? "Yaklaşan etkinliklerden nasıl haberdar olabilirim?" : "How can I stay updated about upcoming events?",
    a: lang === 'tr'
      ? "Bültenimize abone olarak, sosyal medyada bizi takip ederek veya web sitemizi düzenli olarak kontrol ederek güncel kalabilirsiniz."
      : "You can stay updated by subscribing to our newsletter, following us on social media, or regularly checking our website for event announcements.",
  },
  {
    q: lang === 'tr' ? "Webinar veya atölye konusu önerebilir miyim?" : "Can I propose a webinar or workshop topic?",
    a: lang === 'tr'
      ? "Kesinlikle! Webinar konuları ve atölye temaları için önerilerinizi bekliyoruz. Lütfen teklifinizle birlikte bize ulaşın."
      : "Absolutely! We welcome suggestions for webinar topics and workshop themes. Please contact us with your proposal.",
  },
];
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Page Header -->
  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('contact.title')}</h1>
      <p class="text-white/70 mt-2">{t('contact.subtitle')}</p>
    </div>
  </div>

  <!-- Contact Content -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 items-start">

        <!-- Form -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">{lang === 'tr' ? 'Bize Mesaj Gönderin' : 'Send Us a Message'}</h2>
          <form id="contactForm" class="flex flex-col gap-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Ad' : 'First Name'} *</label>
                <input type="text" id="firstName" name="firstName" required class="input-field" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Soyad' : 'Last Name'} *</label>
                <input type="text" id="lastName" name="lastName" required class="input-field" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-1">{t('contact.form.email')} *</label>
                <input type="email" id="email" name="email" required class="input-field" />
              </div>
              <div>
                <label for="institution" class="block text-sm font-medium text-navy mb-1">{lang === 'tr' ? 'Kurum' : 'Institution'}</label>
                <input type="text" id="institution" name="institution" class="input-field" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-navy mb-1">{t('contact.form.subject')} *</label>
              <select id="subject" name="subject" required class="input-field">
                <option value="">{lang === 'tr' ? 'Konu seçin...' : 'Choose a subject...'}</option>
                <option value="general">{lang === 'tr' ? 'Genel Soru' : 'General Inquiry'}</option>
                <option value="membership">{lang === 'tr' ? 'Üyelik Sorusu' : 'Membership Question'}</option>
                <option value="events">{lang === 'tr' ? 'Etkinlik Bilgisi' : 'Event Information'}</option>
                <option value="webinars">{lang === 'tr' ? 'Webinar Kaydı' : 'Webinar Registration'}</option>
                <option value="collaboration">{lang === 'tr' ? 'İşbirliği Teklifi' : 'Collaboration Proposal'}</option>
                <option value="other">{lang === 'tr' ? 'Diğer' : 'Other'}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-1">{t('contact.form.message')} *</label>
              <textarea id="message" name="message" rows="5" required class="input-field resize-y"></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input type="checkbox" id="newsletter" name="newsletter" class="mt-0.5 accent-navy" />
              <label for="newsletter" class="text-sm text-gray-600">
                {lang === 'tr' ? 'Etkinlik ve webinarlar hakkında güncellemeler almak için bültenimize abone olun' : 'Subscribe to our newsletter for updates about events and webinars'}
              </label>
            </div>
            <div>
              <button type="submit"
                class="inline-flex items-center px-6 py-3 rounded-md bg-red text-white font-medium hover:bg-red-hover transition-colors">
                {t('contact.form.send')}
              </button>
            </div>
            <div id="contactFormMessage"></div>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-xl font-semibold text-navy mb-6">{t('contact.info.title')}</h2>
          <div class="flex flex-col gap-6">
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">{t('contact.info.email')}</h4>
              <a href="mailto:turkey.rsg@gmail.com" class="text-navy-mid hover:text-navy transition-colors">turkey.rsg@gmail.com</a>
            </div>
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">{t('contact.info.social')}</h4>
              <ul class="flex flex-col gap-1.5">
                {['Twitter', 'LinkedIn', 'GitHub', 'YouTube', 'Instagram'].map((platform) => (
                  <li>
                    <a href={`https://${platform.toLowerCase()}.com/${platform === 'LinkedIn' ? 'company/' : ''}rsgturkey`}
                      target="_blank" rel="noopener noreferrer"
                      class="text-sm text-navy-mid hover:text-navy transition-colors">
                      {platform}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-8">
        {lang === 'tr' ? 'Sıkça Sorulan Sorular' : 'Frequently Asked Questions'}
      </h2>
      <div class="flex flex-col gap-2">
        {faqs.map((faq) => (
          <div class="bg-white border border-border rounded-lg overflow-hidden">
            <button
              class="w-full flex justify-between items-center px-5 py-4 text-left text-sm font-medium text-navy hover:bg-navy-light transition-colors"
              aria-expanded="false"
              onclick="const b=this.nextElementSibling;const open=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',String(!open));b.style.display=open?'none':'block'"
            >
              {faq.q}
              <span class="text-xl font-light text-gray-400 ml-4 shrink-0">+</span>
            </button>
            <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed" style="display:none;">
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @reference "../styles/global.css";
  .input-field {
    @apply w-full border border-border rounded-md px-3 py-2 text-sm focus:outline-none focus:border-navy-mid transition-colors bg-white;
  }
</style>

<script>
  const contactForm = document.getElementById('contactForm') as HTMLFormElement;
  const msgDiv = document.getElementById('contactFormMessage');
  if (contactForm && msgDiv) {
    contactForm.addEventListener('submit', function(e) {
      e.preventDefault();
      msgDiv.className = 'mt-2 p-3 rounded bg-green-50 text-green-800 border border-green-200 text-sm';
      msgDiv.textContent = 'Thank you for your message! We will get back to you soon.';
      this.reset();
    });
  }
</script>
