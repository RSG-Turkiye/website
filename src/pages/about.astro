---
import BaseLayout from '../layouts/BaseLayout.astro';
import CommitteeCard from '../layouts/CommitteeCard.astro';
import { getCommittees } from '../data/committees';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "About Us - RSG Turkey";
const committees = getCommittees(lang);
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Page Header -->
  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('about.title')}</h1>
    </div>
  </div>

  <!-- Who We Are -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">{t('about.whoWeAre.title')}</h2>
          <p class="text-gray-600 leading-relaxed mb-3">{t('about.whoWeAre.description')}</p>
          <p class="text-gray-600 leading-relaxed">{t('about.whoWeAre.detail')}</p>
        </div>
        <div>
          <img src="/images/foraboutpage.jpeg" alt="RSG Turkey Community"
            class="w-full rounded-lg border border-border" />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border border-b">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('about.whatWeDo.title')}</h2>
      <p class="text-gray-500 text-center max-w-xl mx-auto mb-10">{t('about.whatWeDo.subtitle')}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { title: t('about.symposiums.title'), desc: t('about.symposiums.description') },
          { title: t('about.webinars.title'), desc: t('about.webinars.description') },
          { title: t('about.presentations.title'), desc: t('about.presentations.description') },
          {
            title: lang === 'tr' ? 'Makale Kulübü' : 'Journal Club',
            desc: lang === 'tr'
              ? 'Güncel biyoinformatik makalelerini birlikte okuyup tartışıyoruz. Akademik okuma alışkanlığını ve eleştirel düşünceyi destekleyen düzenli buluşmalar.'
              : 'We read and discuss current bioinformatics papers together — regular meetups that build academic reading habits and critical thinking.',
          },
          {
            title: lang === 'tr' ? 'Uluslararası Ağ' : 'International Network',
            desc: lang === 'tr'
              ? 'ISCB Öğrenci Konseyi üyeliği sayesinde dünya genelindeki araştırmacılarla bağlantı kurma ve uluslararası konferanslara katılım fırsatları.'
              : 'Through ISCB Student Council membership, opportunities to connect with researchers worldwide and participate in international conferences.',
          },
          {
            title: lang === 'tr' ? 'Fırsat Paylaşımı' : 'Opportunity Sharing',
            desc: lang === 'tr'
              ? 'MSc, PhD ve PostDoc pozisyonları, burs ve konferans fırsatları Slack kanalımız üzerinden anında üyelerimizle paylaşılıyor.'
              : 'MSc, PhD, and PostDoc positions, scholarships, and conference opportunities shared instantly with members via our Slack channel.',
          },
        ].map(({ title, desc }) => (
          <div class="bg-white border border-[#C4CEEA] rounded-lg p-5 hover:border-navy-mid transition-colors">
            <h4 class="font-semibold text-navy mb-2">{title}</h4>
            <p class="text-sm text-gray-500 leading-relaxed m-0">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ISCB Affiliation -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-semibold text-navy mb-4">ISCB Student Council Affiliation</h2>
          <p class="text-gray-600 leading-relaxed mb-3">We are proud to be a member of the International Society for Computational Biology (ISCB) Student Council.</p>
          <p class="text-gray-600 leading-relaxed mb-4">The ISCB Student Council provides a framework for communication and interaction among students and postdocs working in computational biology and bioinformatics worldwide.</p>
          <ul class="space-y-2">
            {['Access to international conferences and events', 'Networking opportunities with global researchers', 'Educational resources and training programs', 'Collaboration opportunities with other RSGs'].map((item) => (
              <li class="flex items-start gap-2 text-gray-600 text-sm">
                <span class="text-navy font-bold mt-0.5">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="text-center p-8 bg-navy-light border border-[#C4CEEA] rounded-lg">
          <img src="/logo/iscb-logo.png" alt="ISCB Student Council" class="max-h-16 mx-auto mb-4" />
          <h4 class="font-semibold text-navy mb-1">ISCB Student Council</h4>
          <p class="text-sm text-gray-500 mb-4">International Society for Computational Biology</p>
          <a href="https://iscbsc.org/" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded border border-navy text-navy text-sm font-medium hover:bg-navy hover:text-white transition-colors no-underline">
            Visit ISCB Student Council
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Committees -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-semibold text-navy text-center mb-2">{t('about.committees.title')}</h2>
      <p class="text-gray-500 text-center max-w-xl mx-auto mb-10">{t('about.committees.subtitle')}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {committees.map((committee) => (
          <div class={committee.members.length >= 3 ? 'col-span-full' : committee.members.length === 2 ? 'md:col-span-2 lg:col-span-2' : ''}>
            <CommitteeCard
              name={committee.name}
              description={committee.description}
              members={committee.members}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
