---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageTitle = "Resources - RSG Turkey";

const resources = [
  {
    category: t('resources.educational.title'),
    items: [
      { title: "Bioinformatics: Where to Start?", description: "A simplified resource list to provide a solution to the question of where/how to start regarding bioinformatics.", type: "guide", link: "#", tags: ["beginner", "learning-path"] },
      { title: "Computational Biology Fundamentals", description: "Basic concepts and methodologies in computational biology and bioinformatics.", type: "course", link: "#", tags: ["fundamentals", "course"] },
      { title: "Statistical Analysis in Bioinformatics", description: "Statistical methods commonly used in bioinformatics research and data analysis.", type: "tutorial", link: "#", tags: ["statistics", "analysis"] },
    ]
  },
  {
    category: t('resources.tools.title'),
    items: [
      { title: "Sequence Analysis Tools", description: "Collection of tools for DNA/RNA sequence analysis, alignment, and annotation.", type: "tools", link: "#", tags: ["sequence-analysis", "alignment"] },
      { title: "Protein Structure Analysis", description: "Tools for protein structure prediction, analysis, and visualization.", type: "tools", link: "#", tags: ["protein-structure", "prediction"] },
      { title: "Single-Cell Analysis Pipeline", description: "Comprehensive pipeline for single-cell RNA sequencing data analysis.", type: "pipeline", link: "#", tags: ["single-cell", "rna-seq"] },
    ]
  },
  {
    category: t('resources.databases.title'),
    items: [
      { title: "Genomic Databases", description: "Access to major genomic databases and repositories for research data.", type: "database", link: "#", tags: ["genomics", "data"] },
      { title: "Protein Databases", description: "Protein sequence and structure databases for research and analysis.", type: "database", link: "#", tags: ["proteins", "structures"] },
      { title: "Expression Data Repositories", description: "Gene expression data repositories and analysis platforms.", type: "database", link: "#", tags: ["expression", "transcriptomics"] },
    ]
  },
  {
    category: t('resources.career.title'),
    items: [
      { title: "Career Development Guide", description: "Guidance for career development in computational biology and bioinformatics.", type: "guide", link: "#", tags: ["career", "development"] },
      { title: "Job Opportunities", description: "Current job openings and opportunities in the field of computational biology.", type: "jobs", link: "#", tags: ["jobs", "opportunities"] },
    ]
  }
];

const externalLinks = [
  { title: "ISCB Student Council", description: "International Society for Computational Biology Student Council", url: "https://www.iscb.org/iscb-student-council" },
  { title: "Bioinformatics.org", description: "Open access to the world's computational biology community", url: "https://www.bioinformatics.org" },
  { title: "NCBI Resources", description: "National Center for Biotechnology Information resources and tools", url: "https://www.ncbi.nlm.nih.gov" },
  { title: "EMBL-EBI", description: "European Bioinformatics Institute resources and services", url: "https://www.ebi.ac.uk" },
];
---

<BaseLayout pageTitle={pageTitle}>

  <!-- Page Header -->
  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl font-bold text-white">{t('resources.title')}</h1>
      <p class="text-white/70 mt-2">{t('resources.subtitle')}</p>
    </div>
  </div>

  <!-- Resources by Category -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      {resources.map((category) => (
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-navy pb-2 border-b-2 border-navy inline-block mb-6">
            {category.category}
          </h2>
          <div class="flex flex-col">
            {category.items.map((item) => (
              <div class="py-4 border-b border-border">
                <div class="flex items-center gap-2 mb-1">
                  <a href={item.link} class="font-semibold text-navy hover:text-navy-mid transition-colors">{item.title}</a>
                  <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{item.type}</span>
                </div>
                <p class="text-sm text-gray-500 leading-relaxed mb-2">{item.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <span class="inline-block text-xs px-2 py-0.5 rounded bg-[#F7F7F6] text-gray-400 border border-border">{tag}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- External Links -->
  <section class="bg-[#F7F7F6] py-16 border-t border-border">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-xl font-semibold text-navy mb-6">{lang === 'tr' ? 'Harici Kaynaklar' : 'External Resources'}</h2>
      <ul class="flex flex-col">
        {externalLinks.map((link) => (
          <li class="py-4 border-b border-border">
            <a href={link.url} target="_blank" rel="noopener noreferrer"
              class="font-medium text-navy-mid hover:text-navy transition-colors">
              {link.title}
            </a>
            <span class="text-sm text-gray-500"> — {link.description}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>
