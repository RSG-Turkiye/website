---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('webinars');
  const enWebinars = all.filter(w => w.id.startsWith('en/'));
  const allIds = new Set(all.map(w => w.id));
  return enWebinars.map((webinar) => {
    const slug = webinar.id.slice(3); // strip 'en/'
    return {
      params: { slug },
      props: { webinar, hasTrTranslation: allIds.has(`tr/${slug}`) },
    };
  });
}

const { webinar, hasTrTranslation } = Astro.props;
const { Content } = await render(webinar);
const { title, date, description, image, speaker, speakerTitle, speakerAffiliation, topic, keyTakeaways, youtubeUrl, slidesUrl } = webinar.data;
const slug = webinar.id.slice(3);

const videoId = youtubeUrl
  ? youtubeUrl.replace(/.*(?:youtu\.be\/|v=|embed\/)([^?&]+).*/, '$1')
  : null;
---

<BaseLayout pageTitle={title} translationUrl={hasTrTranslation ? `/tr/webinars/${slug}` : '/tr/webinars'}>
  <div class="py-10 pb-16">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Header -->
      <header class="mb-8 pb-6 border-b border-border">
        <div class="flex items-center gap-2 flex-wrap mb-4">
          <span class="inline-block text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded bg-red-tint text-red">Webinar</span>
          {topic && <span class="inline-block text-xs font-medium px-2.5 py-1 rounded bg-navy-light text-navy-mid">{topic}</span>}
          <span class="text-sm text-gray-400">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {hasTrTranslation && (
            <a href={`/tr/webinars/${slug}`}
              class="ml-auto inline-flex items-center gap-1 px-2.5 py-1 rounded border border-border text-xs text-gray-500 hover:bg-navy-light hover:border-navy-mid transition-colors no-underline">
              🇹🇷 Türkçe oku
            </a>
          )}
        </div>
        <h1 class="text-3xl font-bold text-navy leading-tight mb-2">{title}</h1>
        {description && <p class="text-gray-500 text-lg leading-relaxed">{description}</p>}
      </header>

      <!-- Two-column: video + sidebar -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 mb-6">

        <!-- Video + body content -->
        <div class="flex flex-col">
          {videoId ? (
            <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:0.5rem;">
              <iframe
                src={`https://www.youtube.com/embed/${videoId}`}
                title={title}
                style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
              </iframe>
            </div>
          ) : (
            <div class="aspect-video bg-navy-light rounded-lg flex items-center justify-center">
              <p class="text-gray-400 text-sm">Recording not yet available</p>
            </div>
          )}
          {slidesUrl && (
            <div class="mt-3">
              <a href={slidesUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded border border-border text-sm text-gray-600 font-medium hover:bg-navy-light transition-colors no-underline">
                View Slides →
              </a>
            </div>
          )}
          <div class="post-content mt-6">
            <h2>About the Talk</h2>
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="flex flex-col gap-5">

          <!-- Speaker card -->
          {speaker && (
            <div class="rounded-lg border border-[#C4CEEA] bg-navy-light p-5">
              {image && (
                <img src={image} alt={speaker}
                  class="w-full max-h-48 object-cover rounded-md mb-4" />
              )}
              <p class="font-semibold text-navy text-base">{speaker}</p>
              {speakerTitle && <p class="text-sm text-navy-mid">{speakerTitle}</p>}
              {speakerAffiliation && <p class="text-xs text-gray-500 mt-0.5">{speakerAffiliation}</p>}
            </div>
          )}

          <!-- Key takeaways -->
          {keyTakeaways.length > 0 && (
            <div class="rounded-lg border border-border bg-white p-5">
              <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">What you'll learn</p>
              <ul class="flex flex-col gap-2">
                {keyTakeaways.map((item: string) => (
                  <li class="flex items-start gap-2 text-sm text-gray-700 leading-snug">
                    <span class="mt-0.5 shrink-0 w-4 h-4 rounded-full bg-red-tint text-red text-xs flex items-center justify-center font-bold">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>

      <footer class="mt-10 pt-6 border-t border-border">
        <a href="/webinars"
          class="inline-flex items-center px-4 py-2 rounded border border-navy text-navy text-sm font-medium hover:bg-navy hover:text-white transition-colors no-underline">
          ← Back to Webinars
        </a>
      </footer>

    </div>
  </div>
</BaseLayout>
