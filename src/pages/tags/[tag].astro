---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ id, data }) => id.startsWith('en/') && !data.draft && data.type !== 'webinar');
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={`Tag: ${tag}`}>

  <div class="bg-navy py-12 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-white/60 text-sm mb-1">Tag</p>
      <h1 class="text-3xl font-bold text-white">"{tag}"</h1>
    </div>
  </div>

  <section class="bg-white py-10">
    <div class="max-w-3xl mx-auto px-6">
      {posts.map((post: any) => (
        <article class="py-4 border-b border-border">
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-1">
            <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            {post.data.author && post.data.author !== 'RSG Turkey' && <span>{post.data.author}</span>}
          </div>
          <h3 class="text-base font-semibold mb-1">
            <a href={`/blog/${post.id.replace(/^en\//, '')}`} class="text-navy hover:text-navy-mid transition-colors">
              {post.data.title}
            </a>
          </h3>
          {post.data.description && <p class="text-sm text-gray-500 leading-relaxed mb-2">{post.data.description}</p>}
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.slice(0, 3).map((t: string) => (
                <span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-navy-light text-navy-mid">{t}</span>
              ))}
            </div>
          )}
        </article>
      ))}

      <div class="mt-6">
        <a href="/blog"
          class="inline-flex items-center px-4 py-2 rounded border border-navy text-navy text-sm font-medium hover:bg-navy hover:text-white transition-colors no-underline">
          ← Back to Blog
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
