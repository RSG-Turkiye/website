---
---
<button
  class="cursor-pointer flex items-center justify-center w-9 h-9 rounded border border-[#E5E4DF] hover:border-[#3D5A9E] transition-colors bg-transparent"
  id="languageToggle"
  aria-label="Toggle language"
>
  <div class="relative w-6 h-4">
    <img src="/flags/en.svg" alt="English" class="flag flag-en absolute inset-0 w-full h-full object-cover rounded-sm" />
    <img src="/flags/tr.svg" alt="Turkish" class="flag flag-tr absolute inset-0 w-full h-full object-cover rounded-sm" />
  </div>
</button>

<script>
  function initLanguageToggle() {
    const languageToggle = document.getElementById('languageToggle');
    if (!languageToggle) return;

    const currentPath = window.location.pathname;
    let currentLang = currentPath.startsWith('/tr') ? 'tr' : 'en';
    document.documentElement.setAttribute('data-lang', currentLang);

    languageToggle.addEventListener('click', () => {
      const currentLang = document.documentElement.getAttribute('data-lang') || 'en';
      const newLang = currentLang === 'en' ? 'tr' : 'en';
      document.documentElement.setAttribute('data-lang', newLang);

      const currentPath = window.location.pathname;
      let newPath;
      if (newLang === 'tr') {
        newPath = currentPath === '/' ? '/tr' : (currentPath.startsWith('/tr/') ? currentPath : '/tr' + currentPath);
      } else {
        newPath = currentPath === '/tr' ? '/' : (currentPath.startsWith('/tr/') ? currentPath.replace('/tr', '') : currentPath);
      }
      window.location.href = newPath;
    });
  }

  document.addEventListener('DOMContentLoaded', initLanguageToggle);
</script>

<style>
  .flag-en { opacity: 1; z-index: 2; }
  .flag-tr { opacity: 0; z-index: 1; }

  :global(html[data-lang="tr"]) .flag-en { opacity: 0; z-index: 1; }
  :global(html[data-lang="tr"]) .flag-tr { opacity: 1; z-index: 2; }
</style>
