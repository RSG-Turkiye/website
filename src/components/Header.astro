---
import LanguageIcon from './LanguageIcon.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'tr' ? '/tr' : '';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-navy h-16 border-b border-[#1a2744]">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-full gap-4">

    <!-- Logo / Brand -->
    <a href={prefix || '/'} class="flex items-center gap-2 text-white font-bold text-lg shrink-0 no-underline">
      <img src="/logo/rsgturkey_logo.png" alt="RSG Turkiye Logo" width="36" height="36" class="rounded bg-white p-0.5" />
      <span class="hidden sm:inline">{t('hero.title')}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1">
      <a href={prefix || '/'} class="nav-link">{t('nav.home')}</a>
      <a href={`${prefix}/about`} class="nav-link">{t('nav.about')}</a>
      <a href={`${prefix}/blog`} class="nav-link">{t('nav.blog')}</a>

      <!-- Webinars dropdown -->
      <div class="relative group">
        <a href={`${prefix}/webinars`} class="nav-link">{t('nav.webinars')}</a>
        <div class="dropdown-menu">
          <a href={`${prefix}/webinars#2026`} class="dropdown-item">2026</a>
          <a href={`${prefix}/webinars#2025`} class="dropdown-item">2025</a>
          <a href={`${prefix}/webinars#2024`} class="dropdown-item">2024</a>
          <a href={`${prefix}/webinars#2023`} class="dropdown-item">2023</a>
          <a href={`${prefix}/webinars#2022`} class="dropdown-item">2022</a>
        </div>
      </div>

      <a href={`${prefix}/resources`} class="nav-link">{t('nav.resources')}</a>
      <a href={`${prefix}/learning-paths`} class="nav-link">{t('nav.learningPaths')}</a>
      <a id="membersNavLink" href="/members" class="nav-link hidden">{t('nav.members')}</a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2 shrink-0">
      <a id="joinBtn" href={`${prefix}/join`} class="hidden items-center px-4 py-1.5 rounded bg-red text-white text-sm font-medium hover:bg-red-hover transition-colors no-underline">
        {t('nav.join')}
      </a>
      <!-- Auth area: fully rendered by JS after /api/me check -->
      <div id="authArea" class="hidden lg:block"></div>
      <LanguageIcon />
      <!-- Hamburger -->
      <button
        id="mobileMenuBtn"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="lg:hidden flex items-center justify-center w-9 h-9 rounded text-white hover:bg-white/10 transition-colors"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobileNav" class="hidden lg:hidden bg-navy border-t border-white/10 px-6 pb-4 flex-col">
    <a href={prefix || '/'} class="mobile-link">{t('nav.home')}</a>
    <a href={`${prefix}/about`} class="mobile-link">{t('nav.about')}</a>
    <a href={`${prefix}/blog`} class="mobile-link">{t('nav.blog')}</a>
    <a href={`${prefix}/webinars`} class="mobile-link">{t('nav.webinars')}</a>
    <a href={`${prefix}/resources`} class="mobile-link">{t('nav.resources')}</a>
    <a href={`${prefix}/learning-paths`} class="mobile-link">{t('nav.learningPaths')}</a>
    <a id="membersMobileLink" href="/members" class="mobile-link hidden">{t('nav.members')}</a>
    <a href={`${prefix}/join`} class="mt-3 flex items-center justify-center px-4 py-2 rounded bg-red text-white text-sm font-medium no-underline">
      {t('nav.join')}
    </a>
    <div id="mobileAuthArea" class="mt-2"></div>
  </div>
</header>

<style>
  @reference "../styles/global.css";

  /* Nav links: white text, red underline on active/hover */
  .nav-link {
    @apply px-3 py-1.5 text-sm font-medium text-white/90 rounded hover:text-white hover:bg-white/10 transition-colors no-underline;
  }

  /* Dropdown panel */
  .dropdown-menu {
    @apply hidden absolute top-full left-0 mt-1 min-w-[160px] bg-white rounded shadow-lg border border-border py-1 z-10;
  }

  .group:hover .dropdown-menu {
    @apply flex flex-col;
  }

  .dropdown-item {
    @apply block px-4 py-2 text-sm text-navy hover:bg-navy-light hover:text-navy-mid no-underline transition-colors;
  }

  /* Mobile links */
  .mobile-link {
    @apply block py-2.5 text-sm text-white/90 hover:text-white border-b border-white/10 no-underline;
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobileMenuBtn');
    var nav = document.getElementById('mobileNav');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      var open = nav.classList.toggle('hidden');
      nav.classList.toggle('flex', !open);
      btn.setAttribute('aria-expanded', String(!open));
    });
  })();

  // Auth state
  (function () {
    var authArea = document.getElementById('authArea');
    var mobileAuthArea = document.getElementById('mobileAuthArea');
    if (!authArea || !mobileAuthArea) return;

    fetch('/api/me')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var joinBtn = document.getElementById('joinBtn');
        if (joinBtn && (!data.user || !data.user.is_member)) {
          joinBtn.classList.remove('hidden');
          joinBtn.classList.add('lg:inline-flex');
        }
        if (data.user) {
          var ml = document.getElementById('membersNavLink');
          var mml = document.getElementById('membersMobileLink');
          if (ml) ml.classList.remove('hidden');
          if (mml) mml.classList.remove('hidden');
        }
        authArea.classList.remove('hidden');
        if (!data.user) {
          authArea.innerHTML = '<a href="/auth/login" style="display:inline-flex;align-items:center;padding:6px 16px;border-radius:6px;border:1px solid rgba(255,255,255,0.3);color:white;font-size:14px;font-weight:500;text-decoration:none;">Sign In</a>';
          mobileAuthArea.innerHTML = '<a href="/auth/login" style="display:flex;align-items:center;justify-content:center;padding:8px 16px;border-radius:6px;border:1px solid rgba(255,255,255,0.3);color:white;font-size:14px;font-weight:500;text-decoration:none;">Sign In</a>';
        }
        if (data.user) {
          var profileHref = data.profile ? '/account' : '/account/setup';
          var avatarHtml = data.profile && data.profile.avatar_url
            ? '<img src="' + data.profile.avatar_url + '" style="width:20px;height:20px;border-radius:50%;object-fit:cover;" />'
            : '<span style="width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,0.2);display:inline-flex;align-items:center;justify-content:center;font-size:11px;">👤</span>';
          var displayName = data.profile ? data.profile.display_name : 'Account';
          var memberBadge = data.user.is_member ? '<span style="font-size:10px;padding:1px 6px;border-radius:99px;background:rgba(34,197,94,0.2);color:#16a34a;font-weight:600;">Member</span>' : '';

          authArea.innerHTML =
            '<div style="position:relative;">' +
              '<button id="userMenuBtn" style="display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:6px;border:1px solid rgba(255,255,255,0.3);background:transparent;color:white;font-size:14px;font-weight:500;cursor:pointer;">' +
                avatarHtml +
                '<span>' + displayName + '</span>' + memberBadge +
                '<svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="opacity:0.7"><path d="M2 4l4 4 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
              '</button>' +
              '<div id="userMenu" style="display:none;position:absolute;top:calc(100% + 8px);right:0;min-width:160px;background:white;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.12);border:1px solid #e5e7eb;padding:4px;z-index:100;">' +
                '<a href="' + profileHref + '" style="display:block;padding:8px 12px;font-size:14px;color:#0f2045;text-decoration:none;border-radius:6px;" onmouseover="this.style.background=\'#f3f4f6\'" onmouseout="this.style.background=\'\'">My Profile</a>' +
                '<form action="/auth/logout" method="POST" style="margin:0;">' +
                  '<button type="submit" style="display:block;width:100%;padding:8px 12px;font-size:14px;color:#dc2626;text-align:left;background:transparent;border:none;border-radius:6px;cursor:pointer;" onmouseover="this.style.background=\'#fef2f2\'" onmouseout="this.style.background=\'\'">Sign Out</button>' +
                '</form>' +
              '</div>' +
            '</div>';

          // Toggle dropdown
          var menuBtn = document.getElementById('userMenuBtn');
          var menu = document.getElementById('userMenu');
          menuBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
          });
          document.addEventListener('click', function () {
            menu.style.display = 'none';
          });

          mobileAuthArea.innerHTML =
            '<a href="' + profileHref + '" style="display:flex;align-items:center;justify-content:center;padding:8px 16px;border-radius:6px;border:1px solid rgba(255,255,255,0.3);color:white;font-size:14px;font-weight:500;text-decoration:none;margin-bottom:8px;">My Profile</a>' +
            '<form action="/auth/logout" method="POST" style="margin:0;">' +
              '<button type="submit" style="display:flex;width:100%;align-items:center;justify-content:center;padding:8px 16px;border-radius:6px;border:1px solid rgba(255,255,255,0.3);background:transparent;color:white;font-size:14px;font-weight:500;cursor:pointer;">Sign Out</button>' +
            '</form>';
        }
      })
      .catch(function () {
        authArea.classList.remove('hidden');
        var joinBtn = document.getElementById('joinBtn');
        if (joinBtn) { joinBtn.classList.remove('hidden'); joinBtn.classList.add('lg:inline-flex'); }
      });
  })();
</script>
