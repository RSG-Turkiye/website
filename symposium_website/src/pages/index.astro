---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpeakerCard from "../components/SpeakerCard.astro";
import SponsorLogo from "../components/SponsorLogo.astro";
import { useTranslations, getLangFromUrl } from "../i18n/ui";
import { speakers, getSpeakersByEdition } from "../data/speakers";
import { sponsors, getSponsorsByEdition } from "../data/sponsors";
import { latestEdition } from "../data/editions";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === "tr" ? "/tr" : "";

const latestSpeakers = getSpeakersByEdition(latestEdition.year);
const latestSponsors = getSponsorsByEdition(latestEdition.year);
---

<BaseLayout
  pageTitle={t("nav.home")}
  translationUrl={lang === "en" ? "/tr/" : "/"}
>
  <!-- Hero -->
  <section class="relative bg-navy text-white overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center opacity-10"
      style={`background-image: url('${latestEdition.posterImage}')`}
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 py-24 sm:py-32 flex flex-col items-center text-center gap-6">
      <span
        class="inline-block bg-red/20 text-red border border-red/30 text-xs font-semibold px-4 py-1 rounded-full uppercase tracking-widest"
      >
        {latestEdition.title}
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight max-w-3xl">
        {t("hero.tagline")}
      </h1>
      <p class="text-lg text-white/75 max-w-2xl leading-relaxed">
        {t("hero.subtitle")}
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-2">
        <a
          href={`${prefix}/about`}
          class="px-6 py-3 rounded-lg bg-white text-navy font-semibold hover:bg-navy-light transition-colors text-sm"
        >
          {t("hero.cta.about")}
        </a>
        <a
          href={`${prefix}/schedule`}
          class="px-6 py-3 rounded-lg border border-white/30 text-white font-semibold hover:bg-white/10 transition-colors text-sm"
        >
          {t("nav.schedule")}
        </a>
      </div>

      <!-- Edition meta -->
      <div class="flex flex-wrap justify-center gap-6 mt-4 text-sm text-white/60">
        <span>📅 {latestEdition.date}</span>
        <span>📍 {latestEdition.venue}, {latestEdition.venueCity}</span>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-navy mb-4">{t("home.about.title")}</h2>
      <p class="text-gray-600 leading-relaxed">{t("home.about.body")}</p>
    </div>
  </section>

  <!-- Speakers strip -->
  {
    latestSpeakers.filter((s) => s.photo).length > 0 && (
      <section class="bg-navy-light py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-navy">{t("speakers.title")}</h2>
            <a href={`${prefix}/speakers`} class="text-sm text-navy-mid hover:text-navy transition-colors font-medium">
              {lang === "tr" ? "Tümünü Gör →" : "View All →"}
            </a>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
            {latestSpeakers
              .filter((s) => s.photo)
              .map((sp) => (
                <SpeakerCard speaker={sp} compact={true} />
              ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Sponsors -->
  {
    latestSponsors.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-bold text-navy text-center mb-8">{t("home.sponsors.title")}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {latestSponsors.map((sp) => (
            <SponsorLogo sponsor={sp} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
