---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SessionRow from "../../components/SessionRow.astro";
import { useTranslations, getLangFromUrl } from "../../i18n/ui";
import { getSessionsByEdition } from "../../data/sessions";
import { latestEdition } from "../../data/editions";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sessions = getSessionsByEdition(latestEdition.year);
---

<BaseLayout pageTitle={t("schedule.title")} translationUrl="/schedule">
  <section class="bg-navy text-white py-16">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">{t("schedule.title")}</h1>
      <p class="text-white/70 text-lg">{t("schedule.subtitle")}</p>
    </div>
  </section>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="bg-white rounded-xl border border-border overflow-hidden">
      <div class="bg-navy-light px-6 py-4 border-b border-border">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-navy">{latestEdition.title}</h2>
          <span class="text-sm text-gray-500">{latestEdition.date}</span>
        </div>
        <p class="text-sm text-gray-500 mt-1">📍 {latestEdition.venue}, {latestEdition.venueCity}</p>
      </div>
      <div class="p-4 space-y-2">
        {sessions.map((session) => <SessionRow session={session} />)}
      </div>
    </div>
    <p class="text-xs text-gray-400 text-center mt-4">Program değişikliğe tabidir. Güncel bilgi için bizi takip edin.</p>
  </div>
</BaseLayout>
