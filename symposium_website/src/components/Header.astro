---
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  translationUrl?: string;
}

const { lang, translationUrl } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === "tr" ? "/tr" : "";
const altLang = lang === "tr" ? "en" : "tr";
const altPrefix = altLang === "tr" ? "/tr" : "";

// Nav: anchor-based items scroll on homepage, link to homepage anchor from other pages
const navLinks = [
  { href: `${prefix}/`, label: t("nav.home"), anchor: false },
  { href: `${prefix}/editions`, label: t("nav.editions"), anchor: false },
  { href: `${prefix}/venue`, label: t("nav.venue"), anchor: false },
  { href: `${prefix}/sponsors`, label: t("nav.sponsors"), anchor: false },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === `${prefix}/` || currentPath === `${prefix}`;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-navy h-16 border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 h-full flex items-center justify-between gap-4">
    <!-- Logo -->
    <a href={`${prefix}/`} class="flex items-center gap-2.5 shrink-0">
      <img
        src="/logo/rsgturkey_logo_white.png"
        alt="RSG-Türkiye"
        class="h-8 w-auto"
      />
      <span class="hidden sm:block text-white/70 text-xs leading-tight border-l border-white/20 pl-2.5">
        Student<br />Symposium
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1">
      {
        navLinks.map(({ href, label, anchor }) => {
          const isActive = !anchor && (
            currentPath === href ||
            (href !== `${prefix}/` && currentPath.startsWith(href))
          );
          return (
            <a
              href={href}
              class:list={[
                "px-3 py-1.5 rounded text-sm transition-colors",
                isActive
                  ? "bg-white/20 text-white font-medium"
                  : "text-white/80 hover:bg-white/10 hover:text-white",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Lang toggle + hamburger -->
    <div class="flex items-center gap-2">
      <a
        href={translationUrl || `${altPrefix}/`}
        class="text-xs text-white/70 hover:text-white border border-white/20 rounded px-2 py-1 transition-colors"
      >
        {altLang === "tr" ? "TR" : "EN"}
      </a>
      <button id="hamburger" aria-label="Open menu" class="lg:hidden flex flex-col gap-1.5 p-1">
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden absolute top-16 left-0 right-0 bg-navy border-t border-white/10 px-4 py-2">
    {
      navLinks.map(({ href, label }) => (
        <a href={href} class="block py-2.5 text-white/90 border-b border-white/10 last:border-0 hover:text-white text-sm">
          {label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById("hamburger");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
  // Close mobile menu on anchor link click
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu.classList.add("hidden"))
  );
</script>
